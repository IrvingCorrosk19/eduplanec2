@model SchoolManager.Models.SchoolScheduleConfiguration
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Configuración de jornada escolar";
}

<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <h1>Configuración de jornada escolar</h1>
            <p class="text-muted small mb-0">Defina la jornada y el sistema generará automáticamente los bloques horarios. No se puede regenerar si ya hay horarios asignados a bloques.</p>
            <p class="text-muted small mb-0">Las horas usan <strong>formato 24 h</strong> (07:00, 13:00), estándar en la aplicación.</p>
        </div>
    </section>
    <section class="content">
        <div class="container-fluid">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
            }
            <div class="card card-outline card-primary">
                <div class="card-header">
                    <h3 class="card-title">Jornada</h3>
                </div>
                <div class="card-body">
                    <form asp-action="SaveConfiguration" method="post">
                        <input type="hidden" asp-for="SchoolId" />
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="RecessAfterAfternoonBlockNumber" />
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <h5 class="mb-3">Mañana</h5>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="MorningStartTime" class="control-label">Hora de inicio</label>
                                    <input asp-for="MorningStartTime" type="text" class="form-control" value="@(Model.MorningStartTime.ToString("HH:mm"))" placeholder="07:00" pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]" maxlength="5" />
                                    <span asp-validation-for="MorningStartTime" class="text-danger"></span>
                                    <small class="form-text text-muted">Formato 24 h (07:00, 13:00)</small>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="MorningBlockDurationMinutes" class="control-label">Duración (min)</label>
                                    <input asp-for="MorningBlockDurationMinutes" type="number" min="1" max="120" class="form-control" placeholder="45" />
                                    <span asp-validation-for="MorningBlockDurationMinutes" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="MorningBlockCount" class="control-label">Cantidad de bloques</label>
                                    <input asp-for="MorningBlockCount" type="number" min="1" max="20" class="form-control" placeholder="8" />
                                    <span asp-validation-for="MorningBlockCount" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <p class="text-muted small">Ej: 07:00, 35 min, 8 bloques → 07:00–07:35, 07:35–08:10, …</p>
                        <div id="morningCalc" class="alert alert-info py-2 small mb-0 mt-2"></div>

                        <hr class="my-4" />
                        <h5 class="mb-3">Recreo</h5>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="RecessAfterMorningBlockNumber" class="control-label">Después del bloque n.º (mañana y tarde)</label>
                                    <input asp-for="RecessAfterMorningBlockNumber" type="number" min="1" max="20" class="form-control" placeholder="4" />
                                    <span asp-validation-for="RecessAfterMorningBlockNumber" class="text-danger"></span>
                                    <small class="form-text text-muted">El mismo número en <strong>ambas jornadas</strong>: recreo justo después de ese bloque de clase (1 = tras el 1.º, …), con la <strong>misma duración en minutos</strong>. Si coincide con la cantidad de bloques de <strong>mañana</strong> y hay tarde, en mañana no hay recreo entre clases (solo el hueco hasta la hora de inicio de tarde). Si en tarde hay menos bloques que ese número, en tarde tampoco habrá recreo intermedio.</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="RecessDurationMinutes" class="control-label">Duración (min)</label>
                                    <input asp-for="RecessDurationMinutes" type="number" min="1" max="180" class="form-control" placeholder="30" />
                                    <span asp-validation-for="RecessDurationMinutes" class="text-danger"></span>
                                    <small class="form-text text-muted">Duración del recreo <strong>entre clases</strong> (mañana y tarde, según configure abajo). Con jornada tarde, también es el <strong>mínimo</strong> del hueco entre la última clase de mañana y el inicio de tarde.</small>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h5 class="mb-3">Tarde (opcional)</h5>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label asp-for="AfternoonStartTime" class="control-label">Hora de inicio</label>
                                    <input asp-for="AfternoonStartTime" type="text" class="form-control" value="@(Model.AfternoonStartTime?.ToString("HH:mm"))" placeholder="13:00" pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]" maxlength="5" />
                                    <span asp-validation-for="AfternoonStartTime" class="text-danger"></span>
                                    <small class="form-text text-muted">Formato 24 h (ej. 13:00, 14:30)</small>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="AfternoonBlockDurationMinutes" class="control-label">Duración (min)</label>
                                    <input asp-for="AfternoonBlockDurationMinutes" type="number" min="1" max="120" class="form-control" placeholder="45" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label asp-for="AfternoonBlockCount" class="control-label">Cantidad de bloques</label>
                                    <input asp-for="AfternoonBlockCount" type="number" min="0" max="20" class="form-control" placeholder="0" />
                                </div>
                            </div>
                        </div>
                        <p class="text-muted small">Deje vacío o 0 si solo usa jornada de mañana. Con tarde, la hora de inicio debe dejar al menos la duración mínima de recreo después del fin de mañana.</p>
                        <div id="afternoonCalc" class="alert alert-secondary py-2 small mb-0 mt-2"></div>

                        <hr class="my-4" />
                        <div class="form-group">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="forceRegenerate" name="forceRegenerate" value="true" />
                                <label class="form-check-label" for="forceRegenerate">
                                    Forzar regeneración: eliminar todas las asignaciones de horario y regenerar bloques (los docentes tendrán que volver a asignar materias).
                                </label>
                            </div>
                            <small class="text-muted">Marque solo si ya hay horarios asignados y desea cambiar la configuración de bloques.</small>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">Guardar y generar bloques</button>
                            <a href="@Url.Action("Index", "TimeSlot")" class="btn btn-secondary">Ver bloques horarios</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            function parseTime(str) {
                if (!str || typeof str !== 'string') return null;
                var parts = str.trim().match(/^(\d{1,2}):(\d{2})/);
                if (!parts) return null;
                return parseInt(parts[1], 10) * 60 + parseInt(parts[2], 10);
            }
            function formatMinutes(min) {
                if (min == null || isNaN(min)) return '--:--';
                var h = Math.floor(min / 60) % 24;
                var m = min % 60;
                return (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m;
            }
            function updateCalc() {
                var startInput = document.querySelector('input[name="MorningStartTime"]');
                var durationInput = document.querySelector('input[name="MorningBlockDurationMinutes"]');
                var countInput = document.querySelector('input[name="MorningBlockCount"]');
                var recessInput = document.querySelector('input[name="RecessDurationMinutes"]');
                var afterInput = document.querySelector('input[name="RecessAfterMorningBlockNumber"]');
                var morningDiv = document.getElementById('morningCalc');
                var afternoonDiv = document.getElementById('afternoonCalc');
                var aftStartEl = document.querySelector('input[name="AfternoonStartTime"]');
                var aftDurEl = document.querySelector('input[name="AfternoonBlockDurationMinutes"]');
                var aftCntEl = document.querySelector('input[name="AfternoonBlockCount"]');
                var aftRecessHidden = document.querySelector('input[name="RecessAfterAfternoonBlockNumber"]');
                if (!startInput || !durationInput || !countInput || !morningDiv) return;
                var recessMin = Math.max(1, parseInt(recessInput && recessInput.value, 10) || 30);
                var startMin = parseTime(startInput.value);
                var duration = parseInt(durationInput.value, 10) || 0;
                var count = parseInt(countInput.value, 10) || 0;
                if (afterInput) {
                    afterInput.max = String(Math.max(1, count));
                    var ak = parseInt(afterInput.value, 10);
                    if (isNaN(ak) || ak < 1) ak = 1;
                    if (ak > count) { ak = count; afterInput.value = String(count); }
                }
                if (startMin == null || duration < 1 || count < 1) {
                    morningDiv.innerHTML = 'Ingrese hora de inicio, duración y cantidad de bloques para ver el cálculo.';
                    afternoonDiv.innerHTML = '';
                    return;
                }
                var k = afterInput ? Math.max(1, Math.min(count, parseInt(afterInput.value, 10) || 4)) : Math.min(4, count);
                var lastClassEndMin = k < count
                    ? startMin + k * duration + recessMin + (count - k) * duration
                    : startMin + count * duration;
                var lastClassTime = formatMinutes(lastClassEndMin);
                var recStartMin = startMin + k * duration;
                var recEndMin = recStartMin + recessMin;
                var morningHtml;
                if (k < count) {
                    morningHtml = '<strong>Recreo entre clases:</strong> después del <strong>bloque ' + k + '</strong>, de <strong>' + formatMinutes(recStartMin) + '</strong> a <strong>' + formatMinutes(recEndMin) + '</strong> (' + recessMin + ' min). La última clase de mañana termina a las <strong>' + lastClassTime + '</strong>.';
                } else {
                    morningHtml = '<strong>Sin recreo entre clases de mañana</strong> (valor = cantidad de bloques). Fin de la última clase: <strong>' + lastClassTime + '</strong>. Con tarde, el bloque <strong>Recreo</strong> será desde ahí hasta la hora de inicio de tarde (mín. ' + recessMin + ' min).';
                }
                morningDiv.innerHTML = morningHtml;
                if (aftRecessHidden) aftRecessHidden.value = String(k);
                var earliestAfternoonMin = lastClassEndMin + recessMin;
                var baseAfternoonLine = 'Si hay jornada de tarde, la primera hora posible de inicio es <strong>' + formatMinutes(earliestAfternoonMin) + '</strong> (tras última clase mañana + <strong>' + recessMin + '</strong> min mín.).';
                var aCnt = parseInt(aftCntEl && aftCntEl.value, 10) || 0;
                var aDur = parseInt(aftDurEl && aftDurEl.value, 10) || 0;
                var aftStartMin = parseTime(aftStartEl && aftStartEl.value);
                var afternoonExtra = '';
                if (aftStartMin != null && aDur > 0 && aCnt > 0) {
                    var kA = Math.min(k, aCnt);
                    var lastAftEndMin = kA < aCnt
                        ? aftStartMin + kA * aDur + recessMin + (aCnt - kA) * aDur
                        : aftStartMin + aCnt * aDur;
                    var recAStartMin = aftStartMin + kA * aDur;
                    var recAEndMin = recAStartMin + recessMin;
                    if (kA < aCnt) {
                        afternoonExtra = '<br/><strong>Recreo en tarde (mismo n.º y minutos):</strong> después del <strong>bloque ' + kA + '</strong>, de <strong>' + formatMinutes(recAStartMin) + '</strong> a <strong>' + formatMinutes(recAEndMin) + '</strong>. Fin de la última clase de tarde: <strong>' + formatMinutes(lastAftEndMin) + '</strong>.';
                    } else {
                        afternoonExtra = '<br/><strong>Sin recreo entre clases de tarde</strong> (el número supera la cantidad de bloques de tarde o es igual). Fin de la última clase: <strong>' + formatMinutes(lastAftEndMin) + '</strong>.';
                    }
                }
                afternoonDiv.innerHTML = baseAfternoonLine + afternoonExtra;
            }
            document.querySelectorAll('input[name="MorningStartTime"], input[name="MorningBlockDurationMinutes"], input[name="MorningBlockCount"], input[name="RecessDurationMinutes"], input[name="RecessAfterMorningBlockNumber"], input[name="AfternoonStartTime"], input[name="AfternoonBlockDurationMinutes"], input[name="AfternoonBlockCount"]').forEach(function (el) {
                el.addEventListener('change', updateCalc);
                el.addEventListener('input', updateCalc);
            });
            updateCalc();
        })();
    </script>
}
