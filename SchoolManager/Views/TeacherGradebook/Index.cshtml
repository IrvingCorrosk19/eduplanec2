    <script>
    // =================== DISCIPLINA ===================
    window.estudianteSeleccionado = null;

    function disciplinaFormatAcciones(jsonStr) {
        if (!jsonStr) return '';
        try {
            const arr = JSON.parse(jsonStr);
            if (!Array.isArray(arr) || arr.length === 0) return '';
            const esc = (s) => $('<div/>').text(s).html();
            return '<div class="small text-muted mt-1"><i class="bi bi-list-check me-1"></i>' + arr.map(esc).join(' · ') + '</div>';
        } catch (e) { return ''; }
    }

    function disciplinaAccionesTablaHtml(jsonStr) {
        if (!jsonStr) return '—';
        try {
            const arr = JSON.parse(jsonStr);
            if (!Array.isArray(arr) || arr.length === 0) return '—';
            return arr.map(s => $('<div/>').text(s).html()).join('<br>');
        } catch (e) { return '—'; }
    }

    function disciplineUtcToDateInputPanama(isoUtc) {
        if (isoUtc == null || isoUtc === '') return '';
        const d = new Date(isoUtc);
        if (isNaN(d.getTime())) return '';
        return new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Panama', year: 'numeric', month: '2-digit', day: '2-digit' }).format(d);
    }

    function disciplineUtcToTimeInputPanama(isoUtc) {
        if (isoUtc == null || isoUtc === '') return '';
        const d = new Date(isoUtc);
        if (isNaN(d.getTime())) return '';
        const parts = new Intl.DateTimeFormat('en-GB', { timeZone: 'America/Panama', hour: '2-digit', minute: '2-digit', hour12: false }).formatToParts(d);
        const h = (parts.find(p => p.type === 'hour') || {}).value || '00';
        const m = (parts.find(p => p.type === 'minute') || {}).value || '00';
        return (String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0')).substring(0, 5);
    }

    window.teacherDisciplinaIdNorm = '@Model.TeacherId'.toString().toLowerCase();

    function disciplinaEsPropioRegistro(registro) {
        if (!registro || !registro.reportTeacherId) return false;
        return String(registro.reportTeacherId).toLowerCase() === (window.teacherDisciplinaIdNorm || '');
    }

    window.abrirModalEditarDisciplina = function(reportId, studentId) {
        $.ajax({
            url: '/DisciplineReport/GetForTeacherEdit',
            method: 'GET',
            data: { id: reportId },
            success: function(res) {
                if (!res || !res.success) {
                    Swal.fire({ icon: 'error', title: 'No permitido', text: (res && res.error) || 'No se pudo cargar el registro' });
                    return;
                }
                $('#modalEditDisciplinaReportId').val(res.id);
                $('#modalEditDisciplinaStudentId').val(studentId || res.studentId || '');
                $('#modalEditDisciplinaFecha').val(disciplineUtcToDateInputPanama(res.date));
                $('#modalEditDisciplinaHora').val(disciplineUtcToTimeInputPanama(res.date));
                $('#modalEditDisciplinaTipo').val(res.reportType || 'Comentario');
                $('#modalEditDisciplinaEstado').val(res.status || 'Pendiente');
                $('#modalEditDisciplinaDescripcion').val(res.description || '');
                const cat = res.category || 'Comportamiento';
                if (cat === 'Rendimiento' || cat === 'Comportamiento') {
                    $('#modalEditDisciplinaCategoria').val(cat);
                } else {
                    $('#modalEditDisciplinaCategoria').val('Comportamiento');
                }
                let acciones = [];
                if (res.disciplineActionsJson) {
                    try {
                        const parsed = JSON.parse(res.disciplineActionsJson);
                        if (Array.isArray(parsed)) acciones = parsed;
                    } catch (e) { /* ignore */ }
                }
                document.querySelectorAll('.modal-edit-disciplina-accion-check').forEach(function(cb) {
                    cb.checked = acciones.indexOf(cb.value) >= 0;
                });
                $('#modalEditDisciplinaDocs').val('');
                const modal = new bootstrap.Modal(document.getElementById('modalEditDisciplina'));
                modal.show();
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Error', text: 'No se pudo cargar el registro' });
            }
        });
    };

    window.eliminarRegistroDisciplina = function(reportId, studentId) {
        Swal.fire({
            title: '¿Eliminar registro?',
            text: 'Esta acción no se puede deshacer. Se borrarán también los archivos de evidencia asociados.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (!result.isConfirmed) return;
            $.ajax({
                url: '/DisciplineReport/TeacherDeleteReport',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ reportId: reportId }),
                success: function(response) {
                    if (response.success) {
                        Swal.fire({ icon: 'success', title: 'Eliminado', text: response.message || 'Registro eliminado' });
                        if (studentId && window.cargarHistorialEstudiante) window.cargarHistorialEstudiante(studentId);
                        if ($('#btnFiltrarHistorialDisciplina').length && $('#historialDisciplinaTab').hasClass('show')) {
                            $('#btnFiltrarHistorialDisciplina').trigger('click');
                        }
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: response.error || 'No se pudo eliminar' });
                    }
                },
                error: function(xhr) {
                    let msg = 'No se pudo eliminar';
                    try {
                        const r = xhr.responseJSON;
                        if (r && r.error) msg = r.error;
                    } catch (e) { /* ignore */ }
                    Swal.fire({ icon: 'error', title: 'Error', text: msg });
                }
            });
        });
    };

    $(document).on('click', '#btnGuardarEditDisciplina', function() {
        const reportId = $('#modalEditDisciplinaReportId').val();
        const studentId = $('#modalEditDisciplinaStudentId').val();
        if (!reportId) return;
        const nAcc = document.querySelectorAll('.modal-edit-disciplina-accion-check:checked').length;
        if (nAcc === 0) {
            Swal.fire({ icon: 'warning', title: 'Acciones requeridas', text: 'Debe seleccionar al menos una acción observada.' });
            return;
        }
        const formData = new FormData();
        formData.append('ReportId', reportId);
        formData.append('Date', $('#modalEditDisciplinaFecha').val());
        formData.append('Hora', $('#modalEditDisciplinaHora').val());
        formData.append('ReportType', $('#modalEditDisciplinaTipo').val());
        formData.append('Status', $('#modalEditDisciplinaEstado').val());
        formData.append('Description', $('#modalEditDisciplinaDescripcion').val());
        formData.append('Category', $('#modalEditDisciplinaCategoria').val());
        document.querySelectorAll('.modal-edit-disciplina-accion-check:checked').forEach(function(cb) {
            formData.append('DisciplineActions', cb.value);
        });
        const docsEl = document.getElementById('modalEditDisciplinaDocs');
        if (docsEl && docsEl.files) {
            for (let i = 0; i < docsEl.files.length; i++) {
                formData.append('Documents', docsEl.files[i]);
            }
        }
        $.ajax({
            url: '/DisciplineReport/UpdateWithFilesForTeacher',
            method: 'POST',
            processData: false,
            contentType: false,
            data: formData,
            success: function(response) {
                if (response.success) {
                    const el = document.getElementById('modalEditDisciplina');
                    const inst = bootstrap.Modal.getInstance(el);
                    if (inst) inst.hide();
                    Swal.fire({ icon: 'success', title: 'Actualizado', text: response.message || 'Cambios guardados' });
                    if (studentId && window.cargarHistorialEstudiante) window.cargarHistorialEstudiante(studentId);
                    if ($('#btnFiltrarHistorialDisciplina').length) $('#btnFiltrarHistorialDisciplina').trigger('click');
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: (response.error || '') + (response.details ? '\n' + response.details : '') });
                }
            },
            error: function(xhr) {
                let msg = 'No se pudo guardar';
                try { if (xhr.responseJSON && xhr.responseJSON.error) msg = xhr.responseJSON.error; } catch (e) { /* ignore */ }
                Swal.fire({ icon: 'error', title: 'Error', text: msg });
            }
        });
    });

    window.cargarHistorialEstudiante = function(studentId) {
        $('#historialEstudianteDisciplina').html('<div class="text-center text-muted">Cargando historial...</div>');
        $.ajax({
            url: '/DisciplineReport/GetByStudent',
            method: 'GET',
            data: { studentId: studentId },
            success: function(response) {
                if (!response || response.length === 0) {
                    $('#historialEstudianteDisciplina').html('<div class="text-center text-muted">No hay registros para este estudiante</div>');
                    return;
                }
                const historial = $('<div class="list-group"></div>');
                response.forEach(registro => {
                    const fechaFormateada = registro.date ? (formatDatePanama(registro.date) || 'Fecha no válida') : 'Fecha no válida';

                    // Badge para categoría
                    let categoriaBadge = '';
                    if (registro.categoria === 'Comportamiento') {
                        categoriaBadge = '<span class="badge bg-info me-2"><i class="bi bi-person-exclamation me-1"></i>Comportamiento</span>';
                    } else if (registro.categoria === 'Rendimiento') {
                        categoriaBadge = '<span class="badge bg-success me-2"><i class="bi bi-graph-up me-1"></i>Rendimiento</span>';
                    } else {
                        categoriaBadge = `<span class="badge bg-secondary me-2">${registro.categoria || 'Sin categoría'}</span>`;
                    }

                    const esPropio = disciplinaEsPropioRegistro(registro);
                    const btnEditar = esPropio
                        ? `<button type="button" class="btn btn-sm btn-outline-primary" onclick="abrirModalEditarDisciplina('${registro.id}','${studentId}')" title="Editar"><i class="bi bi-pencil"></i></button>`
                        : '';
                    const btnEliminar = esPropio
                        ? `<button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarRegistroDisciplina('${registro.id}','${studentId}')" title="Eliminar"><i class="bi bi-trash"></i></button>`
                        : '';

                    const item = `
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <span class="badge ${registro.type === 'Comentario' ? 'bg-primary' : 'bg-danger'} me-2">
                                        ${registro.type || 'Sin tipo'}
                                    </span>
                                    ${categoriaBadge}
                                    <span class="badge ${
                                        registro.status === 'Pendiente' ? 'bg-warning text-dark' : 
                                        registro.status === 'Resuelto' ? 'bg-success' : 
                                        'bg-danger bg-opacity-50 text-dark'
                                    }">
                                        ${registro.status || 'Sin estado'}
                                    </span>
                                </div>
                                <div class="d-flex align-items-center gap-1 flex-wrap">
                                    ${btnEditar}
                                    ${btnEliminar}
                                    <button class="btn btn-sm btn-outline-success" onclick="enviarCorreoDisciplinario('${registro.id}', '${studentId}')" title="Enviar correo al estudiante">
                                        <i class="bi bi-envelope me-1"></i>Correo
                                    </button>
                                    <small class="text-muted">${fechaFormateada} ${registro.time || ''}</small>
                                </div>
                            </div>
                            ${disciplinaFormatAcciones(registro.disciplineActionsJson)}
                            <p class="mb-1 mt-2">${registro.description || 'Sin descripción'}</p>
                            <small class="text-muted">Profesor: ${registro.teacher || 'No especificado'}</small>
                        </div>
                    `;
                    historial.append(item);
                });
                $('#historialEstudianteDisciplina').empty().append(historial);
            },
            error: function(xhr, status, error) {
                $('#historialEstudianteDisciplina').html(`<div class="text-center text-danger">Error al cargar historial: ${error}</div>`);
            }
        });
    };

    // Función para enviar correo disciplinario
    window.enviarCorreoDisciplinario = function(disciplineReportId, studentId) {
        // Mostrar modal para mensaje personalizado
        Swal.fire({
            title: 'Enviar Correo al Estudiante',
            html: `
                <div class="mb-3">
                    <label class="form-label">Mensaje adicional (opcional):</label>
                    <textarea id="mensajePersonalizado" class="form-control" rows="3" placeholder="Escriba un mensaje adicional para el estudiante..."></textarea>
                </div>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Se enviará un correo con los detalles del reporte disciplinario y documentos adjuntos.
                </div>
            `,
            showCancelButton: true,
            confirmButtonText: '<i class="bi bi-envelope me-1"></i>Enviar Correo',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d',
            preConfirm: () => {
                const mensaje = document.getElementById('mensajePersonalizado').value;
                return { mensaje: mensaje };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                const mensaje = result.value.mensaje || '';
                
                // Mostrar loading
                Swal.fire({
                    title: 'Enviando correo...',
                    text: 'Por favor espere mientras se envía el correo',
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/DisciplineReport/SendEmailToStudent',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        studentId: studentId,
                        disciplineReportId: disciplineReportId,
                        customMessage: mensaje
                    }),
                    success: function(response) {
                        Swal.close();
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '¡Correo enviado!',
                                text: response.message,
                                confirmButtonText: 'Aceptar'
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error al enviar correo',
                                text: response.message,
                                confirmButtonText: 'Aceptar'
                            });
                        }
                    },
                    error: function(xhr) {
                        Swal.close();
                        let errorMessage = 'Error al enviar el correo';
                        try {
                            const response = xhr.responseJSON;
                            if (response && response.message) {
                                errorMessage = response.message;
                            }
                        } catch (e) {
                            console.error('Error al procesar respuesta:', e);
                        }
                        
                        Swal.fire({
                            icon: 'error',
                            title: 'Error al enviar correo',
                            text: errorMessage,
                            confirmButtonText: 'Aceptar'
                        });
                    }
                });
            }
        });
    };

    window.activarEventListenersDisciplina = function() {
        $('.estudiante-item-disciplina').off('click').on('click', function() {
            $('.estudiante-item-disciplina').removeClass('active');
            $(this).addClass('active');
            const studentId = $(this).data('id');
            const studentName = $(this).data('nombre');
            window.estudianteSeleccionado = { id: studentId, nombre: studentName };
            $('#nombreEstudianteSeleccionado').text(studentName);
            $('#msgSeleccionEstudianteDisciplina').hide();
            $('#formDisciplina').show();
            $('#fechaDisciplina').val(todayDateInputPanama());
            $('#horaDisciplina').val(nowTimeInputPanama());
            $('#formDisciplina .disciplina-accion-check').prop('checked', false);
            window.cargarHistorialEstudiante(studentId);
        });
    };

    window.cargarEstudiantesDisciplina = function() {
        const combo = $('#selGroup').val();
        if (!combo) {
            $('#listaEstudiantesDisciplina').html('<div class="text-center text-muted">Seleccione un grupo para ver los estudiantes</div>');
            return;
        }
        const [subjectId, groupId, gradeLevelId] = combo.split('|');
        $('#listaEstudiantesDisciplina').html('<div class="text-center">Cargando estudiantes...</div>');
        $.ajax({
            url: '/TeacherGradebook/StudentsByGroupAndGrade',
            method: 'GET',
            data: { groupId: groupId, gradeId: gradeLevelId },
            success: function(response) {
                const listaEstudiantes = $('#listaEstudiantesDisciplina');
                listaEstudiantes.empty();
                if (!response || response.length === 0) {
                    listaEstudiantes.html('<div class="text-center text-muted">No se encontraron estudiantes para este grupo</div>');
                    return;
                }
                const container = $('<div class="list-group"></div>');
                response.forEach(student => {
                    const formattedName = formatName(student.fullName);
                    const item = `<div class="list-group-item list-group-item-action estudiante-item-disciplina" data-id="${student.studentId}" data-nombre="${student.fullName}" style="cursor:pointer;"><div class="d-flex align-items-center"><i class="bi bi-person-circle me-2"></i><div><div class="fw-semibold">${formattedName}</div><small class="text-muted">${student.documentId || 'Sin cédula'}</small><br><small class="text-muted">${$('#selGroup option:selected').text()}</small></div></div></div>`;
                    container.append(item);
                });
                listaEstudiantes.append(container);
                window.activarEventListenersDisciplina();
            },
            error: function(xhr, status, error) {
                $('#listaEstudiantesDisciplina').html(`<div class="text-center text-danger">Error al cargar estudiantes: ${error}</div>`);
            }
        });
    };
    </script>

    <script>
        // --- Cambiar filtro de Materia, Grado y Grupo en disciplina ---
        $('#filtroGradoDisciplina').on('change', function() {
            console.log('Filtro de disciplina cambiado');
            const combo = $(this).val();
            console.log('Nuevo valor del combo:', combo);
            
            if (!combo) {
                $('#listaEstudiantesDisciplina').html('<div class="text-center text-muted">Seleccione un grupo para ver los estudiantes</div>');
                return;
            }

            const [subjectId, groupId, gradeLevelId] = combo.split('|');
            console.log('IDs extraídos:', { subjectId, groupId, gradeLevelId });
            
            // Mostrar indicador de carga
            $('#listaEstudiantesDisciplina').html('<div class="text-center">Cargando estudiantes...</div>');
            
            $.ajax({
                url: '/TeacherGradebook/StudentsByGroupAndGrade',
                method: 'GET',
                data: { 
                    subjectId: subjectId, 
                    groupId: groupId, 
                    gradeId: gradeLevelId 
                },
                success: function(response) {
                    console.log('Respuesta del servidor:', response);
                    const listaEstudiantes = $('#listaEstudiantesDisciplina');
                    listaEstudiantes.empty();
                    
                    if (!response || response.length === 0) {
                        listaEstudiantes.html('<div class="text-center text-muted">No se encontraron estudiantes para este grupo</div>');
                        return;
                    }
                    
                    const container = $('<div class="list-group"></div>');
                    response.forEach(student => {
                        const item = `
                            <div class="list-group-item list-group-item-action estudiante-item-disciplina" 
                                 data-id="${student.studentId}" 
                                 data-nombre="${student.fullName}" 
                                 style="cursor:pointer;">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person-circle me-2"></i>
                                    <div>
                                        <div class="fw-semibold">${formatName(student.fullName)}</div>
                                        <small class="text-muted">${student.documentId || 'Sin cédula'}</small><br>
                                        <small class="text-muted">${$('#filtroGradoDisciplina option:selected').text()}</small>
                                    </div>
                                </div>
                            </div>`;
                        container.append(item);
                    });
                    
                    listaEstudiantes.append(container);
                    window.activarEventListenersDisciplina();
                },
                error: function(xhr, status, error) {
                    console.error('Error al cargar estudiantes:', error);
                    console.error('Detalles del error:', xhr.responseText);
                    $('#listaEstudiantesDisciplina').html(`<div class="text-center text-danger">Error al cargar estudiantes: ${error}</div>`);
                }
            });
        });

        // --- Filtro de búsqueda en tiempo real para estudiantes de disciplina ---
        $('#buscarEstudianteDisciplina').on('input', function() {
            const search = $(this).val().toLowerCase();
            $('.estudiante-item-disciplina').each(function() {
                const nombre = $(this).data('nombre').toLowerCase();
                if (nombre.includes(search)) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        });

        // --- Modal de categoría para disciplina ---
        $('#tipoDisciplina').on('change', function() {
            const tipo = $(this).val();
            if (tipo) {
                // Ocultar selección anterior
                $('#categoriaSeleccionadaContainer').hide();
                $('#tipoDisciplinaIcon').hide();
                
                // Mostrar modal
                $('#modalCategoriaDisciplina').modal('show');
            }
        });

        $('#btnConfirmarCategoria').on('click', function() {
            const categoriaSeleccionada = $('input[name="categoriaDisciplina"]:checked').val();
            
            if (!categoriaSeleccionada) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Selección requerida',
                    text: 'Por favor seleccione una categoría'
                });
                return;
            }
            
            // Guardar la categoría seleccionada
            $('#categoriaDisciplinaSeleccionada').val(categoriaSeleccionada);
            
            // Mostrar badge de categoría seleccionada
            let badgeHtml = '';
            if (categoriaSeleccionada === 'Comportamiento') {
                badgeHtml = '<span class="badge bg-info"><i class="bi bi-person-exclamation me-1"></i>Comportamiento</span>';
            } else if (categoriaSeleccionada === 'Rendimiento') {
                badgeHtml = '<span class="badge bg-success"><i class="bi bi-graph-up me-1"></i>Rendimiento</span>';
            }
            
            $('#categoriaSeleccionadaBadge').html(badgeHtml);
            $('#categoriaSeleccionadaContainer').show();
            $('#tipoDisciplinaIcon').show();
            
            // Cerrar modal
            $('#modalCategoriaDisciplina').modal('hide');
        });

        // Limpiar selección cuando se oculta el modal
        $('#modalCategoriaDisciplina').on('hidden.bs.modal', function() {
            $('input[name="categoriaDisciplina"]').prop('checked', false);
        });

        // Botón para cambiar categoría
        $('#btnCambiarCategoria').on('click', function() {
            $('#modalCategoriaDisciplina').modal('show');
        });
    </script>

    <script>
        // =================== DISCIPLINA: HISTORIAL ===================
        $(document).ready(function() {
            // Habilitar/deshabilitar botón según selección de grupo
            $('#filtroGrupoHistorialDisciplina').on('change', function() {
                const combo = $(this).val();
                if (!combo) {
                    $('#btnFiltrarHistorialDisciplina').prop('disabled', true);
                } else {
                    $('#btnFiltrarHistorialDisciplina').prop('disabled', false);
                    
                    // Cargar estudiantes cuando se selecciona un grupo
                    const [subjectId, groupId, gradeId] = combo.split('|');
                    $.ajax({
                        url: '/TeacherGradebook/StudentsByGroupAndGrade',
                        method: 'GET',
                        data: { 
                            subjectId: subjectId, 
                            groupId: groupId, 
                            gradeId: gradeId 
                        },
                        success: function(response) {
                            const select = $('#estudianteHistorialDisciplina');
                            select.html('<option value="">Todos los estudiantes</option>');
                            response.forEach(student => {
                                select.append(`<option value="${student.studentId}">${formatName(student.fullName)}</option>`);
                            });
                        },
                        error: function(xhr, status, error) {
                            console.error('Error al cargar estudiantes:', error);
                        }
                    });
                }
            });

            // Inicializar el estado del botón al cargar
            if (!$('#filtroGrupoHistorialDisciplina').val()) {
                $('#btnFiltrarHistorialDisciplina').prop('disabled', true);
            }

            $('#btnFiltrarHistorialDisciplina').off('click').on('click', function() {
                const fechaInicio = $('#filtroFechaInicioDisciplina').val();
                const fechaFin = $('#filtroFechaFinDisciplina').val();
                const combo = $('#filtroGrupoHistorialDisciplina').val();
                const estudiante = $('#estudianteHistorialDisciplina').val();

                // Solo validar que se haya seleccionado un grupo
                if (!combo) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Debe seleccionar Materia, Grado y Grupo antes de buscar.'
                    });
                    return;
                }

                // Validar que si hay una fecha inicio, también haya fecha fin y viceversa
                if ((fechaInicio && !fechaFin) || (!fechaInicio && fechaFin)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Si desea filtrar por fechas, debe seleccionar tanto la fecha de inicio como la fecha fin.'
                    });
                    return;
                }

                // Validar que fecha fin no sea menor que fecha inicio si ambas están presentes
                if (fechaInicio && fechaFin) {
                    const fechaInicioDate = new Date(fechaInicio);
                    const fechaFinDate = new Date(fechaFin);
                    if (fechaFinDate < fechaInicioDate) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'La fecha fin no puede ser menor que la fecha inicio.'
                        });
                        return;
                    }
                }

                const [subjectId, groupId, gradeLevelId] = combo.split('|');

                let mensajeBusqueda = 'Buscando registros disciplinarios';
                if (fechaInicio && fechaFin) {
                    mensajeBusqueda += ' del ' + fechaInicio + ' al ' + fechaFin;
                } else {
                    mensajeBusqueda += ' de todas las fechas';
                }
                if (estudiante) {
                    mensajeBusqueda += ' para el estudiante seleccionado';
                } else {
                    mensajeBusqueda += ' para todos los estudiantes';
                }

                $('#tablaHistorialDisciplina').html('<div class="text-center text-muted">' + mensajeBusqueda + '...</div>');
                
                // Convertir las fechas solo si están presentes
                const fechaInicioObj = fechaInicio ? new Date(fechaInicio + 'T00:00:00') : null;
                const fechaFinObj = fechaFin ? new Date(fechaFin + 'T23:59:59') : null;
                
                $.ajax({
                    url: '/DisciplineReport/GetFiltered',
                    method: 'GET',
                    data: {
                        fechaInicio: fechaInicio ? fechaInicio + 'T00:00:00' : null,
                        fechaFin: fechaFin ? fechaFin + 'T23:59:59' : null,
                        gradoId: gradeLevelId,
                        groupId: groupId,
                        studentId: estudiante || null
                    },
                    success: function(data) {
                        if (!data || data.length === 0) {
                            $('#tablaHistorialDisciplina').html('<div class="text-center text-muted">No hay registros para los filtros seleccionados</div>');
                            return;
                        }
                        let html = `<div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>Estudiante</th>
                                        <th>Fecha</th>
                                        <th>Hora</th>
                                        <th>Tipo</th>
                                        <th>Categoría</th>
                                        <th>Estado</th>
                                        <th>Acciones observadas</th>
                                        <th>Descripción</th>
                                        <th>Opciones</th>
                                    </tr>
                                </thead>
                                <tbody>`;
                        
                        data.forEach(r => {
                            // Badge para tipo
                            let tipoBadge = '';
                            if (r.tipo === 'Comentario') {
                                tipoBadge = '<span class="badge bg-primary">Comentario</span>';
                            } else if (r.tipo === 'Citacion') {
                                tipoBadge = '<span class="badge bg-danger">Citación</span>';
                            } else {
                                tipoBadge = `<span class="badge bg-secondary">${r.tipo || 'Sin tipo'}</span>`;
                            }
                            
                            // Badge para categoría
                            let categoriaBadge = '';
                            if (r.categoria === 'Comportamiento') {
                                categoriaBadge = '<span class="badge bg-info"><i class="bi bi-person-exclamation me-1"></i>Comportamiento</span>';
                            } else if (r.categoria === 'Rendimiento') {
                                categoriaBadge = '<span class="badge bg-success"><i class="bi bi-graph-up me-1"></i>Rendimiento</span>';
                            } else {
                                categoriaBadge = `<span class="badge bg-secondary">${r.categoria || 'Sin categoría'}</span>`;
                            }
                            
                            // Badge para estado
                            let estadoBadge = '';
                            if (r.status === 'Pendiente') {
                                estadoBadge = '<span class="badge bg-warning text-dark">Pendiente</span>';
                            } else if (r.status === 'Resuelto') {
                                estadoBadge = '<span class="badge bg-success">Resuelto</span>';
                            } else if (r.status === 'Escalado') {
                                estadoBadge = '<span class="badge bg-danger bg-opacity-50 text-dark">Escalado</span>';
                            } else {
                                estadoBadge = `<span class="badge bg-secondary">${r.status || 'Sin estado'}</span>`;
                            }

                            const sid = r.studentId || '';
                            const esPropioTabla = r.reportTeacherId && String(r.reportTeacherId).toLowerCase() === (window.teacherDisciplinaIdNorm || '');
                            const btnsGestion = esPropioTabla
                                ? `<button type="button" class="btn btn-sm btn-outline-primary me-1" onclick="abrirModalEditarDisciplina('${r.id}','${sid}')" title="Editar"><i class="bi bi-pencil"></i></button>` +
                                  `<button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarRegistroDisciplina('${r.id}','${sid}')" title="Eliminar"><i class="bi bi-trash"></i></button>`
                                : '<span class="text-muted small">—</span>';

                            html += `<tr>
                                <td>
                                    <div>${r.estudiante || 'Sin nombre'}</div>
                                    <small class="text-muted">${r.documentId || 'Sin cédula'}</small>
                                </td>
                                <td>${r.fecha || 'Sin fecha'}</td>
                                <td>${r.hora || ''}</td>
                                <td>${tipoBadge}</td>
                                <td>${categoriaBadge}</td>
                                <td>${estadoBadge}</td>
                                <td>${disciplinaAccionesTablaHtml(r.disciplineActionsJson)}</td>
                                <td>${r.description || 'Sin descripción'}</td>
                                <td><div class="d-flex flex-wrap gap-1">${btnsGestion}</div></td>
                            </tr>`;
                        });
                        
                        html += '</tbody></table></div>';
                        $('#tablaHistorialDisciplina').html(html);
                    },
                    error: function(xhr) {
                        let msg = 'No se pudo consultar el historial de disciplina.';
                        if (xhr && xhr.responseJSON && xhr.responseJSON.error) {
                            msg = xhr.responseJSON.error;
                        } else if (xhr && xhr.responseText) {
                            msg += ' ' + xhr.responseText;
                        }
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: msg
                        });
                        $('#tablaHistorialDisciplina').html('<div class="text-center text-danger">Error al consultar el historial</div>');
                    }
                });
            });

            // Usar la misma materia/grado/grupo que "Registrar Notas" (#selGroup) en filtros de disciplina, asistencia e historiales.
            function syncSelGroupToTeacherContextSelects() {
                var v = $('#selGroup').val();
                if (!v) return;
                function apply($sel) {
                    if (!$sel.length) return;
                    if ($sel.find('option').filter(function () { return $(this).val() === v; }).length) {
                        $sel.val(v).trigger('change');
                    }
                }
                apply($('#filtroGrupoHistorial'));
                apply($('#filtroGrupoHistorialDisciplina'));
                apply($('#filtroGradoDisciplina'));
                apply($('#filtroGradoAsistencia'));
            }
            $('#selGroup').on('change.syncTeacherCtx', syncSelGroupToTeacherContextSelects);
            syncSelGroupToTeacherContextSelects();
        });
    </script>

    <script>
        $(document).ready(function() {
            // ... existing code ...
            $('#formDisciplina').on('submit', function(e) {
                e.preventDefault(); // Prevenir submit tradicional
                if (!window.estudianteSeleccionado) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Debe seleccionar un estudiante' });
                    return;
                }
                const accionesMarcadas = document.querySelectorAll('#formDisciplina .disciplina-accion-check:checked').length;
                if (accionesMarcadas === 0) {
                    Swal.fire({ icon: 'warning', title: 'Acciones requeridas', text: 'Debe seleccionar al menos una acción observada.' });
                    return;
                }
                const combo = $('#filtroGradoDisciplina').val();
                let subjectId = null, groupId = null, gradeLevelId = null;
                if (combo) {
                    [subjectId, groupId, gradeLevelId] = combo.split('|');
                }
                // Crear FormData para incluir archivos
                const formData = new FormData();
                formData.append('StudentId', window.estudianteSeleccionado.id);
                formData.append('TeacherId', '@Model.TeacherId');
                formData.append('SubjectId', subjectId);
                formData.append('GroupId', groupId);
                formData.append('GradeLevelId', gradeLevelId);
                formData.append('Date', $('#fechaDisciplina').val());
                formData.append('Hora', $('#horaDisciplina').val());
                formData.append('ReportType', $('#tipoDisciplina').val());
                formData.append('Status', $('#estadoDisciplina').val());
                formData.append('Description', $('#descripcionDisciplina').val());
                formData.append('Category', $('#categoriaDisciplinaSeleccionada').val());
                document.querySelectorAll('#formDisciplina .disciplina-accion-check:checked').forEach(function(cb) {
                    formData.append('DisciplineActions', cb.value);
                });
                
                // Agregar archivos si existen
                const documentosInput = document.getElementById('documentosDisciplina');
                if (documentosInput) {
                    const archivos = documentosInput.files;
                    for (let i = 0; i < archivos.length; i++) {
                        formData.append('Documents', archivos[i]);
                    }
                }
                
                $.ajax({
                    url: '/DisciplineReport/CreateWithFiles',
                    method: 'POST',
                    processData: false,
                    contentType: false,
                    data: formData,
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({ icon: 'success', title: '¡Guardado!', text: response.message });
                            $('#formDisciplina')[0].reset();
                            window.cargarHistorialEstudiante(window.estudianteSeleccionado.id);
                            // Mantener el tab de disciplina activo
                            $('#disciplinaTab').addClass('show active');
                            $('#notasTab').removeClass('show active');
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: response.error + (response.details ? '\n\nDetalles: ' + response.details : '') });
                        }
                    },
                    error: function(xhr) {
                        let errorMessage = 'No se pudo guardar el registro';
                        let errorDetails = '';
                        try {
                            const response = xhr.responseJSON;
                            if (response) {
                                errorMessage = response.error || errorMessage;
                                errorDetails = response.details || '';
                            }
                        } catch (e) { console.error('Error al procesar la respuesta:', e); }
                        Swal.fire({ icon: 'error', title: 'Error', text: errorMessage + (errorDetails ? '\n\nDetalles: ' + errorDetails : '') });
                    }
                });
            });
            // ... existing code ...
        });
    </script>

