    <script>
        // ... existing code ...
        // Filtro para promedios finales
        $('#selGroupResumen').on('change', function() {
            loadPromediosFinalesResumen();
        });

        function loadPromediosFinalesResumen() {
            const combo = $('#selGroupResumen').val();
            console.log("Combo seleccionado:", combo);
            if (!combo) return;
            const [subjectId, groupId, gradeLevelId] = combo.split('|');
            console.log("IDs enviados:", { subjectId, groupId, gradeLevelId });
            const teacherId = '@Model.TeacherId';
            $.ajax({
                url: '/TeacherGradebook/GetPromediosFinales',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    teacherId: teacherId,
                    subjectId: subjectId,
                    groupId: groupId,
                    gradeLevelId: gradeLevelId
                }),
                success: function(response) {
                    console.log("Respuesta del backend:", response);
                    const resumenBody = $('#resumenBody');
                    resumenBody.empty();
                    if (response.success && response.data && response.data.length > 0) {
                        // Agrupar por estudiante usando propiedades con mayúscula
                        const estudiantes = {};
                        response.data.forEach(item => {
                            if (!estudiantes[item.studentId]) {
                                console.log('Procesando estudiante:', item.studentFullName, '->', formatName(item.studentFullName));
                                estudiantes[item.studentId] = {
                                    nombre: formatName(item.studentFullName),
                                    documentId: item.documentId || 'Sin cédula',
                                    t1: null,
                                    t2: null,
                                    t3: null,
                                    estado: 'Sin calificar',
                                    promedioFinal: null
                                };
                            }
                            if (item.trimester === '1T') estudiantes[item.studentId].t1 = item.notaFinal;
                            if (item.trimester === '2T') estudiantes[item.studentId].t2 = item.notaFinal;
                            if (item.trimester === '3T') estudiantes[item.studentId].t3 = item.notaFinal;
                        });
                        // Calcular promedio final y estado
                        Object.values(estudiantes).forEach(est => {
                            const notas = [est.t1, est.t2, est.t3].filter(x => typeof x === 'number' && !isNaN(x));
                            est.promedioFinal = notas.length > 0 ? (notas.reduce((a, b) => a + b, 0) / notas.length) : null;
                            est.estado = est.promedioFinal !== null ? (est.promedioFinal >= 3.0 ? 'Aprobado' : 'Reprobado') : 'Sin calificar';
                        });
                        // Renderizar filas
                        Object.values(estudiantes).forEach(est => {
                            // Si el nombre es vacío, null o undefined, mostrar "(Sin nombre)"
                            let nombre = est.nombre;
                            if (!nombre || nombre.trim() === "" || nombre === "undefined") nombre = "(Sin nombre)";
                            const documentId = est.documentId || 'Sin cédula';
                            resumenBody.append(`
                                <tr>
                                    <td>
                                        <div>${nombre}</div>
                                        <small class="text-muted">${documentId}</small>
                                    </td>
                                    <td>${typeof est.t1 === 'number' && !isNaN(est.t1) ? est.t1.toFixed(1) : '0.0'}</td>
                                    <td>${typeof est.t2 === 'number' && !isNaN(est.t2) ? est.t2.toFixed(1) : '0.0'}</td>
                                    <td>${typeof est.t3 === 'number' && !isNaN(est.t3) ? est.t3.toFixed(1) : '0.0'}</td>
                                    <td><strong>${typeof est.promedioFinal === 'number' && !isNaN(est.promedioFinal) ? est.promedioFinal.toFixed(1) : '0.0'}</strong></td>
                                    <td class="${est.estado === 'Aprobado' ? 'text-success' : 'text-danger'} fw-semibold">${est.estado}</td>
                                </tr>
                            `);
                        });
                    } else {
                        resumenBody.append('<tr><td colspan="6" class="text-center text-muted">No hay datos para mostrar.</td></tr>');
                    }
                },
                error: function() {
                    $('#resumenBody').html('<tr><td colspan="6" class="text-center text-danger">Error al cargar los promedios finales.</td></tr>');
                }
            });
        }
        // Cargar al inicio
        $('#resumen-tab').on('click', function() {
            loadPromediosFinalesResumen();
        });

        // ===== FUNCIONALIDAD DE CONSEJERÍA =====
        
        // Cargar grupos de consejería
        function loadCounselorGroups() {
            $.ajax({
                url: '@Url.Action("GetCounselorGroups", "TeacherGradebook")',
                method: 'GET',
                success: function(groups) {
                    const select = $('#selGrupoConsejeria');
                    select.empty().append('<option value="">-- Seleccionar grupo --</option>');
                    
                    if (groups && groups.length > 0) {
                        groups.forEach(function(group) {
                            select.append(`<option value="${group.gradeId}|${group.groupId}" data-grade-id="${group.gradeId}" data-group-id="${group.groupId}">${group.displayName}</option>`);
                        });
                    } else {
                        select.append('<option value="" disabled>No tienes grupos asignados como consejero</option>');
                    }
                },
                error: function() {
                    $('#selGrupoConsejeria').html('<option value="" disabled>Error al cargar grupos</option>');
                }
            });
        }

        // Cargar promedios por materia para el grupo de consejería
        function loadCounselorGroupAverages() {
            const selectedGroup = $('#selGrupoConsejeria').val();
            const trimester = $('#selTrimesterConsejeria').val();
            
            if (!selectedGroup || !trimester) {
                $('#bodyPromediosConsejeria').html('<tr><td colspan="100%" class="text-center text-muted">Selecciona un grupo y trimestre para ver los promedios</td></tr>');
                updateCounselorStatistics(0, 0, 0, 0);
                return;
            }

            const [gradeId, groupId] = selectedGroup.split('|');
            
            // Mostrar indicador de carga
            $('#bodyPromediosConsejeria').html('<tr><td colspan="100%" class="text-center">Cargando promedios...</td></tr>');
            
            $.ajax({
                url: '/TeacherGradebook/GetCounselorGroupAverages',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    groupId: groupId,
                    gradeId: gradeId,
                    trimester: trimester
                }),
                success: function(response) {
                    if (response.success && response.data) {
                        renderCounselorAveragesTable(response.data);
                        updateCounselorStatistics(
                            response.data.students.length,
                            response.data.subjects.length,
                            response.data.generalAverage,
                            response.data.approvalPercentage
                        );
                    } else {
                        $('#bodyPromediosConsejeria').html('<tr><td colspan="100%" class="text-center text-muted">No hay datos disponibles</td></tr>');
                        updateCounselorStatistics(0, 0, 0, 0);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error al cargar promedios:', error);
                    $('#bodyPromediosConsejeria').html('<tr><td colspan="100%" class="text-center text-danger">Error al cargar los promedios</td></tr>');
                    updateCounselorStatistics(0, 0, 0, 0);
                }
            });
        }

        // Renderizar la tabla de promedios
        function renderCounselorAveragesTable(data) {
            const headerRow = $('#headerMateriasConsejeria');
            const bodyContainer = $('#bodyPromediosConsejeria');
            
            // Limpiar contenido anterior
            headerRow.empty();
            bodyContainer.empty();
            
            // Crear encabezado con materias
            headerRow.append('<th style="min-width: 200px; position: sticky; left: 0; background-color: #f8f9fa; z-index: 11;">Estudiante</th>');
            
            if (data.subjects && data.subjects.length > 0) {
                data.subjects.forEach(function(subject) {
                    headerRow.append(`
                        <th style="min-width: 120px; text-align: center; writing-mode: horizontal-tb; white-space: nowrap; transform: none;">
                            <div style="padding: 8px; font-size: 0.9em; font-weight: 600;">
                                ${subject.name}
                            </div>
                        </th>
                    `);
                });
                
                // Agregar columna de promedio general
                headerRow.append('<th style="min-width: 100px; text-align: center; background-color: #e3f2fd;">Promedio</th>');
            } else {
                headerRow.append('<th class="text-center">No hay materias</th>');
            }
            
            // Crear filas de estudiantes
            if (data.students && data.students.length > 0) {
                data.students.forEach(function(student) {
                    let row = `<tr>
                        <td style="position: sticky; left: 0; background-color: white; z-index: 1; font-weight: 600;">
                            <div>${formatName(student.fullName)}</div>
                            <small class="text-muted">${student.documentId || 'Sin cédula'}</small>
                        </td>`;
                    
                    let totalScore = 0;
                    let validScores = 0;
                    
                    // Agregar celdas de promedios por materia
                    data.subjects.forEach(function(subject) {
                        const average = student.averages[subject.id] || 0;
                        const displayAverage = average > 0 ? average.toFixed(1) : '-';
                        const cellClass = average >= 3.0 ? 'text-success' : (average > 0 ? 'text-danger' : 'text-muted');
                        
                        row += `<td class="text-center ${cellClass} counselor-average-cell">${displayAverage}</td>`;
                        
                        if (average > 0) {
                            totalScore += average;
                            validScores++;
                        }
                    });
                    
                    // Calcular y mostrar promedio general del estudiante
                    const generalAverage = validScores > 0 ? (totalScore / validScores) : 0;
                    const generalDisplay = generalAverage > 0 ? generalAverage.toFixed(1) : '-';
                    const generalClass = generalAverage >= 3.0 ? 'text-success' : (generalAverage > 0 ? 'text-danger' : 'text-muted');
                    
                    row += `<td class="text-center ${generalClass} fw-bold" style="background-color: #f8f9fa;">${generalDisplay}</td>`;
                    row += '</tr>';
                    
                    bodyContainer.append(row);
                });
            } else {
                bodyContainer.append('<tr><td colspan="100%" class="text-center text-muted">No hay estudiantes en este grupo</td></tr>');
            }
        }

        // Actualizar estadísticas de consejería
        function updateCounselorStatistics(totalStudents, totalSubjects, generalAverage, approvalPercentage) {
            $('#totalEstudiantes').text(totalStudents);
            $('#totalMaterias').text(totalSubjects);
            $('#promedioGeneral').text(generalAverage > 0 ? generalAverage.toFixed(1) : '-');
            $('#porcentajeAprobados').text(approvalPercentage > 0 ? approvalPercentage.toFixed(1) + '%' : '-');
        }

        // Event listeners para consejería
        $('#consejeria-tab').on('click', function() {
            loadCounselorGroups();
        });

        $('#selGrupoConsejeria, #selTrimesterConsejeria').on('change', function() {
            loadCounselorGroupAverages();
        });

        // ... existing code ...
    </script>

}


