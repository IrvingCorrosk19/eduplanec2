                                                                        <input class="form-check-input" type="radio" name="categoriaDisciplina" id="categoriaRendimiento" value="Rendimiento">
                                                                        <label class="form-check-label" for="categoriaRendimiento">
                                                                            <i class="bi bi-graph-up me-2"></i>Rendimiento
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                            <button type="button" class="btn btn-primary" id="btnConfirmarCategoria">Confirmar</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="modal fade" id="modalEditDisciplina" tabindex="-1" aria-labelledby="modalEditDisciplinaLabel" aria-hidden="true">
                                                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
