<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
@section Scripts {
    <script>
        // Función helper global para formatear nombres como "Apellido, Nombre"
        // El servicio ya devuelve el FullName en formato "Apellido, Nombre"
        function formatName(fullName) {
            if (!fullName) return '(Sin nombre)';
            const trimmed = fullName.trim();
            return trimmed || '(Sin nombre)';
        }

        function escapeAttr(text) {
            if (text == null || text === '') return '';
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

        function escapeHtml(text) {
            if (text == null || text === '') return '';
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        /** Etiqueta corta del tipo para cabeceras compactas (tooltip lleva el nombre completo). */
        function gradebookTypeShortLabel(type) {
            const t = (type || '').toLowerCase();
            if (t === 'notas de apreciación') return 'Aprec.';
            if (t === 'ejercicios diarios') return 'Ejerc.';
            if (t === 'examen final') return 'Examen';
            if (t === 'recuperación') return 'Recup.';
            if (t === 'tarea') return 'Tarea';
            if (t === 'parcial') return 'Parcial';
            if (t === 'examen') return 'Examen';
            const s = type || '';
            return s.length > 12 ? s.slice(0, 11) + '…' : s;
        }

        const TZ_PANAMA = 'America/Panama';

        /** Muestra fechas según calendario en Panamá (evita desfase por UTC). */
        function formatDatePanama(value) {
            if (value == null || value === '') return '';
            const s = String(value).trim();
            const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(s);
            if (m) {
                const y = +m[1], mo = +m[2], d = +m[3];
                const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
                return `${d} ${months[mo - 1]}. de ${y}`;
            }
            const dt = new Date(s);
            if (isNaN(dt.getTime())) return '';
            return dt.toLocaleDateString('es-PA', { day: 'numeric', month: 'short', year: 'numeric', timeZone: TZ_PANAMA });
        }

        function todayDateInputPanama() {
            return new Intl.DateTimeFormat('en-CA', { timeZone: TZ_PANAMA, year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date());
        }

        function nowTimeInputPanama() {
            const t = new Date().toLocaleTimeString('en-GB', { timeZone: TZ_PANAMA, hour: '2-digit', minute: '2-digit', hour12: false });
            return t.length >= 5 ? t.substring(0, 5) : t;
        }

        $(document).ready(() => {
            const teacherId = '@Model.TeacherId';
            const students = [];
            const activities = {};
            function clearActivityBuckets() {
                Object.keys(activities).forEach(k => delete activities[k]);
            }
            let scores = {};
            const studentAnnualScores = {};

            console.log("Datos de studentAnnualScores al cargar:", studentAnnualScores);

            // Event listener para mostrar helper de recuperación
            $('#activityType').on('change', function() {
                if ($(this).val().toLowerCase() === 'recuperación') {
                    $('#recuperacionHelper').slideDown();
                } else {
                    $('#recuperacionHelper').slideUp();
                }
            });

            // Función para resetear el formulario
            function resetForm() {
                $('#activityId').val('');
                $('#activityName').val('');
                $('#activityType').val('');
                $('#activityDueDate').val('');
                $('#activityFile').val('');
                $('#recuperacionHelper').hide();
                
                // Resetear UI a modo agregar
                $('#formIcon').removeClass('bi-pencil text-warning').addClass('bi-plus-circle text-success');
                $('#formTitle').text('Agregar Nueva Actividad');
                $('#btnIcon').removeClass('bi-check-circle').addClass('bi-plus-circle');
                $('#btnText').text('Agregar');
            }

            // Función de búsqueda de estudiantes
            $('#searchStudent').on('keyup', function() {
                const searchTerm = $(this).val().toLowerCase();
                $('#bodyRows tr').each(function() {
                    const studentName = $(this).find('td:first-child').text().toLowerCase();
                    const documentId = $(this).find('td:nth-child(2)').text().toLowerCase();
                    if (studentName.includes(searchTerm) || documentId.includes(searchTerm)) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });

            function truncateToOneDecimal(value) {
                if (value === null || value === undefined || value === '') {
                    return 0;
                }
                const numValue = parseFloat(value);
                if (isNaN(numValue)) {
                    return 0;
                }
                return Math.floor(numValue * 10) / 10;
            }

            function validateScore(score) {
                if (isNaN(score)) return 0;
                return Math.max(1.0, Math.min(5.0, score));
            }

            function updateResumenTable() {
                const resumenBody = $('#resumenBody');
                resumenBody.empty();
                
                if (!students || students.length === 0) {
                    resumenBody.append('<tr><td colspan="6" class="text-center text-muted">No hay estudiantes cargados</td></tr>');
                    return;
                }
                
                // Evitar duplicados por id
                const uniqueStudents = [];
                const seen = new Set();
                students.forEach(s => {
                    if (s.id && !seen.has(s.id)) {
                        uniqueStudents.push(s);
                        seen.add(s.id);
                    }
                });
                
                if (uniqueStudents.length === 0) {
                    resumenBody.append('<tr><td colspan="6" class="text-center text-muted">No hay estudiantes válidos</td></tr>');
                    return;
                }
                
                uniqueStudents.forEach(s => {
                    const nombre = formatName(s.fullName);
                    const documentId = s.documentId || 'Sin cédula';
                    const trimesterData = studentAnnualScores[s.id] || {};
                    const t1 = trimesterData['1T'] || 0;
                    const t2 = trimesterData['2T'] || 0;
                    const t3 = trimesterData['3T'] || 0;
                    const count = [t1, t2, t3].filter(n => n > 0).length;
                    const promedio = count > 0 ? ((t1 + t2 + t3) / count) : 0;
                    const truncPromedio = truncateToOneDecimal(promedio);
                    let estado = 'Sin calificar';
                    if (count > 0) {
                        estado = truncPromedio >= 3.0 ? 'Aprobado' : 'Reprobado';
                    }
                    const row = `
                        <tr>
                            <td>
                                <div>${nombre}</div>
                                <small class="text-muted">${documentId}</small>
                            </td>
                            <td>${t1.toFixed(1)}</td>
                            <td>${t2.toFixed(1)}</td>
                            <td>${t3.toFixed(1)}</td>
                            <td><strong>${truncPromedio.toFixed(1)}</strong></td>
                            <td class="${estado === 'Aprobado' ? 'text-success' : (estado === 'Reprobado' ? 'text-danger' : 'text-danger')}">${estado}</td>
                        </tr>`;
                    resumenBody.append(row);
                });
            }

            function saveCurrentScores() {
                $('.score-cell').each(function () {
                    const $cell = $(this);
                    const student = $cell.data('stu');
                    const type = $cell.data('type');
                    const act = $cell.data('act');
                    const value = $cell.text().trim();

                    if (value) {
                        if (!scores[student]) scores[student] = {};
                        if (!scores[student][type]) scores[student][type] = {};
                        scores[student][type][act] = value;
                    }
                });
            }

            function refreshTable() {
                saveCurrentScores();

                const hdrRow = $('#hdrRow');
                hdrRow.html('<th class="text-start gradebook-sticky-name">Estudiante</th><th class="text-start gradebook-sticky-doc">Cédula</th>');

                console.log('Objeto activities:', activities);

                const activeTypes = ['notas de apreciación', 'ejercicios diarios', 'examen final', 'recuperación'];

                let hasActivities = false;
                activeTypes.forEach(type => {
                    if (activities[type] && activities[type].length > 0) {
                        hasActivities = true;
                        activities[type].forEach(a => {
                            console.log('Actividad en ciclo:', a);
                            const fechaEntrega = a.dueDate ? formatDatePanama(a.dueDate) : '';
                            const shortType = gradebookTypeShortLabel(type);
                            const tipParts = [`${a.name} (${type})`];
                            if (fechaEntrega) tipParts.push(`Entrega: ${fechaEntrega}`);
                            const tip = tipParts.join(' · ');
                            const downloadButton = a.pdfUrl
                                ? `<a href="${escapeAttr(a.pdfUrl)}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-light btn-sm gradebook-act-btn" title="Descargar"><i class="bi bi-download"></i></a>`
                                : '';
                            const editButton = a.id
                                ? `<button type="button" class="btn btn-outline-warning btn-sm gradebook-act-btn btn-edit-activity" data-activity-id="${escapeAttr(String(a.id))}" data-activity-name="${escapeAttr(a.name)}" data-activity-type="${escapeAttr(type)}" data-activity-due-date="${escapeAttr(a.dueDate || '')}" title="Editar actividad"><i class="bi bi-pencil"></i></button>`
                                : '';
                            const deleteButton = a.id
                                ? `<button type="button" class="btn btn-outline-danger btn-sm gradebook-act-btn btn-delete-activity" data-activity-id="${escapeAttr(String(a.id))}" title="Eliminar actividad"><i class="bi bi-trash"></i></button>`
                                : '';
                            hdrRow.append(
                                `<th class="text-center gradebook-col-activity align-middle" scope="col" title="${escapeAttr(tip)}">
                                    <div class="gradebook-activity-head">
                                        <div class="gradebook-activity-actions">${downloadButton}${editButton}${deleteButton}</div>
                                        <div class="gradebook-activity-title">${escapeHtml(a.name)}</div>
                                        <span class="gradebook-type-pill">${escapeHtml(shortType)}</span>
                                    </div>
                                </th>`
                            );
                        });
                        const promShort = gradebookTypeShortLabel(type);
                        hdrRow.append(
                            `<th class="text-center gradebook-col-avg" scope="col" title="${escapeAttr('Promedio ' + type)}"><span class="d-block lh-sm fw-semibold">Prom.</span><span class="gradebook-th-sub">${escapeHtml(promShort)}</span></th>`
                        );
                    }
                });

                if (!hasActivities) {
                    hdrRow.append('<th class="text-center gradebook-col-empty gradebook-th-empty" scope="col">Sin actividades</th>');
                }
                hdrRow.append('<th class="text-center gradebook-col-final gradebook-th-final" scope="col">Nota final</th>');

                const body = $('#bodyRows');
                body.empty();

                if (students && students.length > 0) {
                    students.forEach(s => {
                        const formattedName = formatName(s.fullName);
                        const docCell = s.documentId ? escapeHtml(s.documentId) : 'Sin cédula';

                        let row = `<tr data-stu-id="${escapeAttr(String(s.id))}"><td class="gradebook-sticky-name">${escapeHtml(formattedName)}</td><td class="gradebook-sticky-doc" title="${escapeAttr(s.documentId || '')}">${docCell}</td>`;

                        if (hasActivities) {
                            activeTypes.forEach(type => {
                                if (activities[type] && activities[type].length > 0) {
                                    activities[type].forEach(a => {
                                        const savedScore = scores[s.id]?.[type]?.[a.name] || '';
                                        row += `<td contenteditable="true" class="score-cell gradebook-score-cell text-center" data-stu="${escapeAttr(String(s.id))}" data-type="${escapeAttr(type)}" data-act="${escapeAttr(a.name)}">${savedScore !== '' ? Number(savedScore).toFixed(1) : ''}</td>`;
                                    });
                                    const typeClass = type.replace(/\s+/g, '-');
                                    row += `<td class="text-center gradebook-col-avg text-primary avg-${typeClass} fw-semibold"></td>`;
                                }
                            });
                            row += `<td class="text-center gradebook-col-final text-dark fw-bold final-grade"></td>`;
                        } else {
                            row += `<td class="text-muted text-center gradebook-col-empty">—</td>`;
                        }

                        row += `</tr>`;
                        body.append(row);
                    });
                } else {
                    body.append('<tr><td colspan="100%" class="text-center text-muted">No hay estudiantes cargados</td></tr>');
                }

                function procesarCeldaNota($cell) {
                    let value = $cell.text().trim();

                    const student = $cell.data('stu');
                    const type = $cell.data('type');
                    const act = $cell.data('act');

                    if (!value) {
                        // Si la celda queda vacía, elimina el valor de scores
                        if (scores[student] && scores[student][type]) {
                            delete scores[student][type][act];
                        }
                        calcAverages();
                        return;
                    }

                    // Si es un entero o termina en punto, formatear a X.0
                    if (/^[1-5]$/.test(value) || /^[1-5]\.$/.test(value)) {
                        value = value.replace('.', '') + '.0';
                    }

                    const validFormat = /^[1-5](\.[0-9])?$/;
                    if (!validFormat.test(value)) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Formato inválido',
                            text: 'Por favor ingrese un número entre 1.0 y 5.0 con un decimal'
                        });
                        $cell.text('');
                        calcAverages();
                        return;
                    }

                    const numValue = parseFloat(value);
                    if (numValue < 1 || numValue > 5) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Valor fuera de rango',
                            text: 'La calificación debe estar entre 1.0 y 5.0'
                        });
                        $cell.text('');
                        calcAverages();
                        return;
                    }

                    // Siempre formatear el valor final a un decimal
                    const formattedValue = numValue.toFixed(1);
                    $cell.text(formattedValue);

                    if (!scores[student]) scores[student] = {};
                    if (!scores[student][type]) scores[student][type] = {};
                    scores[student][type][act] = formattedValue;

                    calcAverages();
                }

                $('.score-cell').off('blur keypress keydown').on({
                    keypress: function(e) {
                        if (e.which === 13) {
                            e.preventDefault();
                            procesarCeldaNota($(this));
                            $(this).blur();
                            return false;
                        }
                        const $cell = $(this);
                        const currentValue = $cell.text();
                        const selectedText = window.getSelection().toString();
                        if (selectedText === currentValue) {
                            return true;
                        }
                        if (currentValue.includes('.') && currentValue.split('.')[1].length >= 1) {
                            return false;
                        }
                        if (!currentValue.includes('.') && currentValue.length >= 1 && e.which !== 46) {
                            return false;
                        }
                        if (e.which !== 46 && (e.which < 48 || e.which > 57)) {
                            return false;
                        }
                        if (e.which === 46 && currentValue.includes('.')) {
                            return false;
                        }
                        return true;
                    },
                    keydown: function(e) {
                        if (e.which === 13) {
                            e.preventDefault();
                            return false;
                        }
                        if (e.which === 8 || e.which === 46 || e.which === 37 || e.which === 39) {
                            return true;
                        }
                    },
                    paste: function(e) {
                        e.preventDefault();
                        const pastedText = (e.originalEvent.clipboardData || window.clipboardData).getData('text');
                        if (/^[1-5](\.[0-9])?$/.test(pastedText)) {
                            $(this).text(pastedText);
                            procesarCeldaNota($(this));
                            $(this).blur();
                        }
