                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                                <input type="hidden" id="categoriaDisciplinaSeleccionada" value="">
                                                <div class="text-end">
                                                    <button type="submit" class="btn btn-success"><i class="bi bi-save me-2"></i>Guardar</button>
                                                </div>
                                            </form>
                                            
                                            <!-- Modal para seleccionar categoría -->
                                            <div class="modal fade" id="modalCategoriaDisciplina" tabindex="-1" aria-labelledby="modalCategoriaDisciplinaLabel" aria-hidden="true">
                                                <div class="modal-dialog">
