                                    <th>1er Trimestre</th>
                                    <th>2do Trimestre</th>
                                    <th>3er Trimestre</th>
                                    <th>Promedio Final</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody id="resumenBody">
                                <!-- Aquí se llenará dinámicamente con JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: ASISTENCIAS -->
