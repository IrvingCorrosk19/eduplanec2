            function calcAverages() {
                $('#bodyRows tr').each(function () {
                    const row = $(this);
                    const studentId = row.data('stu-id');
                    
                    if (!studentId) return; // Skip if no student ID
                    
                    const activeTypes = ['notas de apreciación', 'ejercicios diarios', 'examen final', 'recuperación'].filter(type => activities[type] && activities[type].length > 0);
                    const typeAvgs = {};

                    activeTypes.forEach(type => {
                        const values = row.find(`.score-cell[data-type="${type}"]`)
                            .map((_, td) => {
                                const val = parseFloat($(td).text());
                                return isNaN(val) ? 0 : val;
                            }).get();
                        const valid = values.filter(n => n > 0);
                        // Calcular promedio (si no hay notas válidas, promedio = 0)
                        const avg = valid.length > 0 ? (valid.reduce((a, b) => a + b, 0) / valid.length) : 0;
                        const truncAvg = Math.floor(avg * 10) / 10;
                        typeAvgs[type] = truncAvg;
                        
                        // Siempre mostrar el promedio (0.0 si está en blanco)
                        row.find(`.avg-${type.replace(/\s+/g, '-')}`).text(truncAvg.toFixed(1));
                    });

                    // LÓGICA ESPECIAL PARA RECUPERACIÓN:
                    // Si existe recuperación y tiene nota > 0, reemplaza el promedio del examen final
                    let typesForFinal = [...activeTypes];
                    if (typeAvgs['recuperación'] && typeAvgs['recuperación'] > 0) {
                        // Si hay recuperación, reemplazar el examen final con recuperación
                        // y no contar ambos en el promedio final
                        typeAvgs['examen final'] = typeAvgs['recuperación'];
                        typesForFinal = typesForFinal.filter(t => t !== 'recuperación');
                    }

                    // Calcular nota final: SOLO con promedios > 0
                    let finalGrade = 0;
                    const validAvgs = typesForFinal.filter(type => typeAvgs[type] > 0);
                    
                    if (validAvgs.length > 0) {
                        // Sumar solo los promedios que sean > 0 y dividir entre la cantidad de promedios válidos
                        finalGrade = validAvgs.reduce((sum, type) => sum + typeAvgs[type], 0) / validAvgs.length;
                    }

                    const truncFinalGrade = Math.floor(finalGrade * 10) / 10;
                    row.find('.final-grade').text(truncFinalGrade.toFixed(1));

                    const trimester = $('#selTrimester').val();
                    if (!studentAnnualScores[studentId]) studentAnnualScores[studentId] = {};
                    studentAnnualScores[studentId][trimester] = truncFinalGrade;
                });

                updateResumenTable();
            }

            function loadStudents(groupId, gradeLevelId, subjectId, callback) {
                $('#hdrRow').html('<th colspan="100%">Cargando estudiantes...</th>');
                $('#bodyRows').html('<tr><td colspan="100%" class="text-center">Cargando estudiantes...</td></tr>');

                $.get(`/TeacherGradebook/StudentsByGroupAndGrade?groupId=${groupId}&gradeId=${gradeLevelId}&subjectId=${subjectId}`)
                    .done(data => {
                        console.log('Estudiantes recibidos:', data);
                        students.length = 0;
                        const ids = new Set();
                        if (data && Array.isArray(data)) {
                            data.forEach(s => {
                                if (s.studentId && !ids.has(s.studentId)) {
                                    students.push({ id: s.studentId, fullName: s.fullName, documentId: s.documentId });
                                    ids.add(s.studentId);
                                }
                            });
                        }
                        scores = {};
                        console.log('Estudiantes cargados:', students);
                        if (callback) callback();
                    })
                    .fail(function(xhr, status, error) {
                        console.error('Error al cargar estudiantes:', error);
                        $('#hdrRow').html('<th colspan="100%">Error al cargar estudiantes</th>');
                        $('#bodyRows').html('<tr><td colspan="100%" class="text-center text-danger">Error al cargar los estudiantes</td></tr>');
                    });
            }

            function loadNotasCargadas(subjectId, groupId, gradeLevelId, trimester) {
                $('#hdrRow').html('<th colspan="100%">Cargando notas...</th>');
                $('#bodyRows').html('<tr><td colspan="100%" class="text-center">Cargando notas...</td></tr>');

                $.ajax({
                    url: '/TeacherGradebook/GetNotasCargadas',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        subjectId,
                        groupId,
                        gradeLevelId,
                        teacherId,
                        trimester
                    }),
                    success: data => {
                        console.log('Datos recibidos del servidor:', data);
                        
                        // Reiniciar todo (los tipos reales son p.ej. "ejercicios diarios", no tarea/parcial)
                        clearActivityBuckets();
                        scores = {};

                        if (data && Array.isArray(data)) {
                            data.forEach(d => {
                                if (!scores[d.studentId]) scores[d.studentId] = {};
                                if (d.notas && Array.isArray(d.notas)) {
                                    d.notas.forEach(nota => {
                                        const tipo = nota.tipo.toLowerCase();
                                        if (!activities[tipo]) activities[tipo] = [];
                                        if (!activities[tipo].some(a => a.name === nota.actividad)) {
                                            activities[tipo].push({ 
                                                name: nota.actividad, 
                                                pdfUrl: nota.pdfUrl, 
                                                id: nota.id, 
                                                dueDate: nota.dueDate 
                                            });
                                        }
                                        if (!scores[d.studentId][tipo]) scores[d.studentId][tipo] = {};
                                        scores[d.studentId][tipo][nota.actividad] = nota.nota ? truncateToOneDecimal(nota.nota) : '';
                                    });
                                }
                            });
                        } else {
                            console.log('No hay datos de notas o el formato es incorrecto');
                        }
                        
                        console.log('Activities después de procesar:', activities);
                        
                        // Verificar si hay actividades
                        const totalActivities = Object.keys(activities).reduce((n, k) => n + (Array.isArray(activities[k]) ? activities[k].length : 0), 0);
                        console.log('Total de actividades:', totalActivities);
                        
                        if (totalActivities === 0) {
                            console.log('No hay actividades para mostrar');
                        }
                        
                        refreshTable();
                    },
                    error: function(xhr, status, error) {
                        console.error('Error al cargar notas:', error);
                        console.error('Detalles del error:', xhr.responseText);
                        $('#hdrRow').html('<th colspan="100%">Error al cargar datos</th>');
                        $('#bodyRows').html('<tr><td colspan="100%" class="text-center text-danger">Error al cargar las notas: ' + error + '</td></tr>');
                    }
                });
            }

            function loadPromediosFinales() {
                const combo = $('#selGroupResumen').val();
                if (!combo) return;

                const [subjectId, groupId, gradeLevelId] = combo.split('|');

                $.ajax({
                    url: '/TeacherGradebook/GetPromediosFinales',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        subjectId: subjectId,
                        groupId: groupId,
                        gradeLevelId: gradeLevelId,
                        teacherId: teacherId
                    }),
                    success: function(response) {
                        const resumenBody = $('#resumenBody');
                        resumenBody.empty();
                        // Limpia el mapa de estudiantes para evitar datos corruptos
                        const map = {};
                        if (response.success && Array.isArray(response.data) && response.data.length > 0) {
                            response.data.forEach(item => {
                                if (!map[item.studentId]) {
                                    map[item.studentId] = {
                                        studentFullName: item.studentFullName && item.studentFullName.trim() ? item.studentFullName : '(Sin nombre)',
                                        documentId: item.documentId || 'Sin cédula',
                                        trimestres: { '1T': 0, '2T': 0, '3T': 0 },
                                        notas: [],
                                    };
                                }
                                map[item.studentId].trimestres[item.trimester] = item.notaFinal ?? 0;
                                map[item.studentId].notas.push(item.notaFinal ?? 0);
                            });
                            Object.values(map).forEach(est => {
                                const nombre = formatName(est.studentFullName);
                                const documentId = est.documentId || 'Sin cédula';
                                const t1 = est.trimestres['1T'] || 0;
                                const t2 = est.trimestres['2T'] || 0;
                                const t3 = est.trimestres['3T'] || 0;
                                const notasValidas = [t1, t2, t3].filter(x => x > 0);
                                const promedioFinal = notasValidas.length ? (notasValidas.reduce((a, b) => a + b, 0) / notasValidas.length) : 0;
                                let estado = 'Sin calificar';
                                if (notasValidas.length) {
                                    estado = promedioFinal >= 3.0 ? 'Aprobado' : 'Reprobado';
                                }
                                const row = `
                                    <tr>
                                        <td>
                                            <div>${nombre}</div>
                                            <small class="text-muted">${documentId}</small>
                                        </td>
                                        <td>${t1.toFixed(1)}</td>
                                        <td>${t2.toFixed(1)}</td>
                                        <td>${t3.toFixed(1)}</td>
                                        <td><strong>${promedioFinal.toFixed(1)}</strong></td>
                                        <td class="${estado === 'Aprobado' ? 'text-success' : (estado === 'Reprobado' ? 'text-danger' : 'text-danger')}">${estado}</td>
                                    </tr>`;
                                resumenBody.append(row);
                            });
                        } else {
                            resumenBody.append('<tr><td colspan="6" class="text-center text-muted">No hay datos para mostrar.</td></tr>');
                        }
                    },
                    error: function() {
                        const resumenBody = $('#resumenBody');
                        resumenBody.empty();
                        resumenBody.append('<tr><td colspan="6" class="text-center text-danger">Error al cargar los promedios finales.</td></tr>');
                    }
                });
            }

