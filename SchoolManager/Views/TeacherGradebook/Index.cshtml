                                                                    <div class="form-check mb-1">
                                                                        <input class="form-check-input disciplina-accion-check" type="checkbox" name="DisciplineActions" id="@aid" value="@a" />
                                                                        <label class="form-check-label" for="@aid">@a</label>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
