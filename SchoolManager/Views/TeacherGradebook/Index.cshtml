                                                        <label class="form-label">Fecha</label>
                                                        <input type="date" class="form-control" id="fechaDisciplina" required autocomplete="off" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Hora</label>
                                                        <input type="time" class="form-control" id="horaDisciplina" required autocomplete="off" />
                                                    </div>
                                                </div>
