                                        <div class="card-header bg-light fw-semibold">Nuevo Registro</div>
                                        <div class="card-body" id="formDisciplinaContainer">
                                            @{
                                                var accionesDisc = new[]
                                                {
                                                    "Uniforme Inapropiado",
                                                    "Corte Inapropiado",
                                                    "Llegada fuera de la hora de entrada",
                                                    "Uso de maquillaje",
                                                    "Uso de lenguaje inapropiado",
                                                    "Burlas o acoso a compañeros",
                                                    "Agresiones verbales",
                                                    "Agresiones físicas",
                                                    "Dañar mobiliario o infraestructura",
                                                    "Ensuciar áreas comunes",
                                                    "Uso indebido de baños",
                                                    "Otras acciones"
                                                };
                                            }
                                            <div class="text-center text-muted" id="msgSeleccionEstudianteDisciplina">
                                                <i class="bi bi-person fs-1"></i><br />
                                                Seleccione un estudiante para crear un registro
                                            </div>
