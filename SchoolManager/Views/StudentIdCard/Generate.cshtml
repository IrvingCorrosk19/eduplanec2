@model SchoolManager.ViewModels.StudentIdCardGenerateViewModel
@{
    Layout = "_SuperAdminLayout";
    var hasCard = Model.HasActiveCard;
    ViewData["Title"] = Model.StudentNotFound ? "Carnet" : (hasCard ? "Carnet — " + DisplayNameHelper.FormatFullName(Model.Card!.FullName) : "Generar Carnet");
    var isVertical = string.Equals(Model.Orientation, "Vertical", StringComparison.OrdinalIgnoreCase);
    var primary = Model.PrimaryColor;
    var bg = Model.BackgroundColor;
    var text = Model.TextColor;
    var borderColor = "#e5e7eb";
    const int maxAllergies = 100;
    string? allergiesTxt = null;
    if (Model.ShowAllergies && !string.IsNullOrWhiteSpace(Model.Allergies))
    {
        var a = Model.Allergies.Trim();
        allergiesTxt = a.Length > maxAllergies ? a[..(maxAllergies - 3)] + "..." : a;
    }
    var hasLogo = !string.IsNullOrWhiteSpace(Model.SchoolLogoUrl);
    var showWm = Model.ShowWatermark && hasLogo;
    var hasEmergencyQr = hasCard && Model.ShowQr && !string.IsNullOrEmpty(Model.Card?.EmergencyInfoQrImageDataUrl);
    // Frente: Cloudinary u otros CDN → URL directa (evita /File/GetSchoolLogo sin cookie en captura PDF); local → proxy autenticado
    string SchoolLogoImgSrc(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        var t = url.Trim();
        if ((t.StartsWith("https://", StringComparison.OrdinalIgnoreCase) || t.StartsWith("http://", StringComparison.OrdinalIgnoreCase))
            && Uri.TryCreate(t, UriKind.Absolute, out var abs)
            && abs.Host.EndsWith("cloudinary.com", StringComparison.OrdinalIgnoreCase))
            return t;
        return "/File/GetSchoolLogo?logoUrl=" + Uri.EscapeDataString(t);
    }
    var frontLogoSrc = SchoolLogoImgSrc(Model.SchoolLogoUrl);
    // Póliza del frente: visibilidad desde configuración del carnet (ShowPolicyNumber); número en datos de la escuela (PolicyNumber)
    var showFrontPolicy = Model.ShowPolicyNumber;
    var policyNumberDisplay = string.IsNullOrWhiteSpace(Model.PolicyNumber) ? "—" : Model.PolicyNumber!.Trim();
    var gradeGroupCompact = "—";
    if (hasCard && Model.Card != null)
    {
        var gradeG = Model.Card.Grade?.Trim() ?? "";
        var groupG = string.IsNullOrWhiteSpace(Model.Card.Group) ? "" : Model.Card.Group.Trim();
        gradeGroupCompact = (string.IsNullOrWhiteSpace(gradeG) && string.IsNullOrWhiteSpace(groupG)) ? "—"
            : string.IsNullOrWhiteSpace(groupG) ? gradeG
            : string.IsNullOrWhiteSpace(gradeG) ? groupG
            : $"{gradeG}-{groupG}";
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    .idcard-generate-alert-print {
        font-size: 0.9rem;
    }

    .idcard-faces-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: flex-start;
        gap: 2rem;
        padding: 1.5rem;
        background: #f0f2f5;
        border-radius: 12px;
    }

    .idcard-face-label {
        text-align: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .idcard-face {
        width: @(isVertical ? "210px" : "342px");
        max-width: 100%;
        aspect-ratio: @(isVertical ? "55 / 85" : "85 / 55");
        height: @(isVertical ? "334px" : "216px");
        max-height: @(isVertical ? "334px" : "216px");
        background: @bg;
        /* Esquinas solo abajo: evita franjas blancas arriba y en laterales del encabezado al imprimir / captura Puppeteer */
        border-radius: 0 0 8px 8px;
        padding: 0;
        position: relative;
        overflow: hidden;
        /* Sin borde superior: evita línea clara entre borde y header; el azul llega al borde del contenido */
        border: 1px solid @borderColor;
        border-top: none;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
        color: @text;
        font-family: 'Inter', 'Segoe UI', Tahoma, sans-serif;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
    }

    /* Respaldo bajo el header azul del frente */
    .idcard-col-front .idcard-face::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 14px;
        background: @primary;
        z-index: 1;
        pointer-events: none;
    }

    .idcard-watermark {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        z-index: 0;
    }

    .idcard-watermark img {
        width: 42%;
        max-width: 100px;
        opacity: 0.14;
        object-fit: contain;
    }

    .idcard-z1 { position: relative; z-index: 2; }

    /* ── HEADER: dominante — logo grande + nombre colegio prominente ── */
    .idcard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 8px 6px 5px;
        background: @primary;
        gap: 4px;
        box-sizing: border-box;
        margin: 0;
        width: 100%;
    }

    /* Logo institucional: sello circular sobre barra de color (referencia diseño frente) */
    .idcard-logo-ring {
        width: 56px;
        height: 56px;
        min-width: 56px;
        min-height: 56px;
        border-radius: 50%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
        flex-shrink: 0;
    }

    .idcard-logo-center {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 50%;
    }

    .idcard-school-name {
        font-size: 8.5pt;
        font-weight: 800;
        color: #fff;
        text-align: center;
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    /* ── FOTO: protagonista absoluta ── */
    .idcard-photo-center {
        display: flex;
        justify-content: center;
        padding-top: 6px;
        flex-shrink: 0;
    }

    .idcard-photo-inner {
        width: 100px;
        height: 100px;
        min-height: 100px;
        border: 1.5px solid @primary;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.04);
        font-size: 6pt;
        font-weight: 600;
        color: @text;
        border-radius: 3px;
        contain: layout paint;
    }

    /* Marco visual fijo 100×100: la imagen puede traer 2×–3× píxeles; object-fit evita deformación y salidas del marco */
    .idcard-photo-inner img {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
        object-position: center center;
        display: block;
        flex-shrink: 0;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
    }

    /* ── DATOS: centrados, mayor jerarquía tipográfica ── */
    .idcard-data-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 6px 8px 0;
        gap: 1px;
        flex-shrink: 0;
    }

    /* ── SPACER: empuja bloque inferior al fondo ── */
    .idcard-spacer {
        flex: 1;
        min-height: 8px;
    }

    /* ── BLOQUE INFERIOR UNIFICADO: Póliza + ID + QR (flush con los bordes) ── */
    .idcard-policy-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #E8F0FA;
        padding: 8px 8px 8px 6px;
        margin: 0;
        border-radius: 0 0 8px 8px;
        flex-shrink: 0;
        min-height: 72px;
        gap: 6px;
    }

    /* Franja gris inferior: ajuste mínimo vía script (máx. 8px, sin tapar datos) */
    .idcard-bottom-footer {
        transition: transform 0s;
    }

    .idcard-bottom-footer.idcard-bottom-footer--raised {
        transform: translateY(calc(-1 * var(--idcard-footer-raise, 0px)));
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-qr,
    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-scan {
        width: 52px;
        min-width: 52px;
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-qr img {
        width: calc(52px * var(--idcard-qr-scale, 0.9));
        height: calc(52px * var(--idcard-qr-scale, 0.9));
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-caption {
        font-size: 4.2pt;
        margin-top: 1px;
        line-height: 1.08;
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-scan {
        height: 52px;
        padding: 3px 2px;
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-icon {
        font-size: 9px;
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-line1 {
        font-size: 5pt;
    }

    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-line2,
    .idcard-bottom-footer.idcard-bottom-footer--qr-compact .policy-emergency-line3 {
        font-size: 4.5pt;
    }

    .idcard-policy-section .policy-text {
        flex: 1;
        min-width: 0;
        padding-right: 4px;
        display: flex;
        align-items: flex-start;
        gap: 5px;
    }

    .idcard-policy-section .policy-shield {
        color: @primary;
        font-size: 9px;
        margin-top: 1px;
        flex-shrink: 0;
        opacity: 0.95;
    }

    .idcard-policy-section .policy-copy {
        min-width: 0;
        flex: 1;
    }

    .idcard-policy-section .policy-label {
        font-size: 6pt;
        font-weight: 700;
        color: @primary;
        line-height: 1.2;
        letter-spacing: 0.01em;
    }

    .idcard-policy-section .policy-number {
        font-size: 7pt;
        font-weight: 700;
        color: @text;
        line-height: 1.25;
        margin-top: 2px;
    }

    .idcard-policy-section .policy-id {
        font-size: 7pt;
        font-weight: 800;
        color: @text;
        margin-top: 3px;
        line-height: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* QR de emergencia (URL https → /StudentIdCard/public/emergency-info), antes en el reverso */
    .idcard-policy-section .policy-emergency-qr,
    .idcard-policy-section .policy-emergency-scan {
        flex-shrink: 0;
        width: 58px;
        min-width: 58px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .idcard-policy-section .policy-emergency-qr img {
        width: 52px;
        height: 52px;
        display: block;
        margin: 0 auto;
        background: #fff;
        border-radius: 4px;
    }

    .idcard-policy-section .policy-emergency-caption {
        font-size: 4.5pt;
        font-weight: 700;
        color: @text;
        line-height: 1.12;
        margin-top: 2px;
        max-width: 58px;
    }

    .idcard-policy-section .policy-emergency-scan {
        flex-shrink: 0;
        width: 58px;
        min-width: 58px;
        height: 58px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: rgba(255, 255, 255, 0.92);
        border: 1.5px solid @primary;
        border-radius: 6px;
        padding: 4px 3px;
        box-sizing: border-box;
        line-height: 1.1;
    }

    .idcard-policy-section .policy-emergency-icon {
        color: @primary;
        font-size: 11px;
        margin-bottom: 1px;
    }

    .idcard-policy-section .policy-emergency-line1 {
        font-size: 5.5pt;
        font-weight: 800;
        color: @primary;
    }

    .idcard-policy-section .policy-emergency-line2,
    .idcard-policy-section .policy-emergency-line3 {
        font-size: 5pt;
        font-weight: 600;
        color: @text;
    }

    .idcard-policy-section .policy-emergency-line3 {
        font-weight: 700;
    }

    /* ── FOOTER: oculto en preview (aparece en PDF) ── */
    .idcard-footer-front {
        display: none;
    }

    .print-actions {
        text-align: center;
        margin-top: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
    }

    @@media print {
        .idcard-faces-row {
            padding: 0 !important;
            background: #fff !important;
        }
        .idcard-face {
            box-shadow: none !important;
        }
    }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-12 text-center mb-3">
            <h2><i class="fas fa-id-card"></i> Carnet estudiantil</h2>
            @if (!Model.StudentNotFound)
            {
                <p class="text-muted small mb-0">@Model.SchoolName</p>
            }
        </div>
    </div>

    @if (Model.StudentNotFound)
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="alert alert-danger"><i class="fas fa-user-slash me-2"></i>Estudiante no encontrado.</div>
                <a href="/StudentIdCard/ui" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver</a>
            </div>
        </div>
    }
    else if (!hasCard)
    {
        @if (Model.UsesCustomPdfTemplate)
        {
            <div class="alert alert-warning py-2 small mx-auto no-print" style="max-width:640px">
                <i class="fas fa-layer-group me-1"></i>
                Esta escuela utiliza una plantilla PDF personalizada. La vista previa web puede variar ligeramente del PDF final.
            </div>
        }
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    Este estudiante no tiene carnet activo. Pulse <strong>Generar carnet</strong> para emitirlo.
                </div>
                <button id="btnGenerate" type="button" class="btn btn-primary btn-lg" onclick="generateCard('@Model.StudentId')">
                    <i class="fas fa-id-card"></i> Generar carnet
                </button>
                <a href="/StudentIdCard/ui" class="btn btn-secondary btn-lg ms-2"><i class="fas fa-arrow-left"></i> Volver</a>
            </div>
        </div>
    }
    else
    {
        @if (Model.UsesCustomPdfTemplate)
        {
            <div class="alert alert-warning py-2 small mx-auto mb-3 no-print" style="max-width:720px">
                <i class="fas fa-file-pdf me-1"></i>
                Este carnet utiliza una plantilla PDF personalizada de la escuela. La vista previa web puede variar ligeramente del PDF final.
            </div>
        }
        <div class="alert alert-info border-0 mx-auto mb-3" style="max-width:720px">
            <i class="fas fa-file-pdf text-primary me-2"></i>
            <strong>Descargue el PDF</strong> para imprimir el carnet (una sola cara — frente).
            <br><small class="text-muted">Nota: el logo en el PDF se imprime con sus colores originales. Use un logo con fondo transparente o colores apropiados para el color primario configurado.</small>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-xl-11">
                <div class="idcard-faces-row">
                    <div class="idcard-col-front">
                        <div class="idcard-face-label no-print">Frente</div>
                        <div class="idcard-face" id="idCardFront">
                            @* Watermark *@
                            @if (showWm)
                            {
                                <div class="idcard-watermark" aria-hidden="true">
                                    <img src="@frontLogoSrc" alt="" onerror="this.parentElement.style.display='none'" />
                                </div>
                            }

                            @* ZONA 1: Header — logo en sello circular + nombre centrado *@
                            <div class="idcard-header idcard-z1">
                                @if (hasLogo)
                                {
                                    <div class="idcard-logo-ring">
                                        <img src="@frontLogoSrc" alt="" class="idcard-logo-center" onerror="this.parentElement.style.display='none'" />
                                    </div>
                                }
                                <div class="idcard-school-name">@Model.SchoolName</div>
                            </div>

                            @* ZONA 2: Foto centrada *@
                            @if (Model.ShowPhoto)
                            {
                                <div class="idcard-photo-center idcard-z1">
                                    <div class="idcard-photo-inner">
                                        <img src="@UserPhotoLinks.HrefForCarnetPreview(Model.Card!.PhotoUrl, 360)"
                                             srcset="@UserPhotoLinks.HrefForCarnetPreview(Model.Card!.PhotoUrl, 280) 2x, @UserPhotoLinks.HrefForCarnetPreview(Model.Card!.PhotoUrl, 420) 3x"
                                             sizes="100px"
                                             decoding="async"
                                             fetchpriority="high"
                                             alt="Foto" />
                                    </div>
                                </div>
                            }

                            @* ZONA 3: Datos centrados — jerarquía tipográfica clara *@
                            <div class="idcard-data-center idcard-z1">
                                <div class="idcard-student-name" style="font-size:9pt;font-weight:700;color:@text;line-height:1.15;max-width:100%">@Html.PersonFullName(Model.Card!.FullName)</div>
                                @if (Model.ShowDocumentId && !string.IsNullOrWhiteSpace(Model.DocumentId))
                                {
                                    <div class="idcard-student-document" style="font-size:6.5pt;color:@text">Cédula: @Model.DocumentId</div>
                                }
                                <div class="idcard-student-grade" style="font-size:6.5pt;color:@text;line-height:1.25">@gradeGroupCompact</div>
                                @if (Model.ShowAcademicYear && !string.IsNullOrWhiteSpace(Model.AcademicYear))
                                {
                                    <div class="idcard-student-year" style="font-size:6.5pt;color:@text">Año: @Model.AcademicYear</div>
                                }
                            </div>

                            @* SPACER: empuja el bloque inferior al fondo *@
                            <div class="idcard-spacer"></div>

                            @* ZONA 4+5: Bloque unificado — Póliza + aviso emergencia (flush con bordes) *@
                            <div class="idcard-policy-section idcard-bottom-footer idcard-z1">
                                <div class="policy-text">
                                    @if (showFrontPolicy)
                                    {
                                        <i class="fas fa-shield-alt policy-shield" aria-hidden="true"></i>
                                        <div class="policy-copy">
                                            <div class="policy-label">Póliza de Seguro Educativo</div>
                                            <div class="policy-number">@policyNumberDisplay</div>
                                        </div>
                                    }
                                    @* Se omite el ID visual en la vista previa (se mantiene en PDF y trazabilidad interna). *@
                                </div>
                                @if (hasEmergencyQr)
                                {
                                    <div class="policy-emergency-qr" aria-label="Escanéame en caso de emergencia">
                                        <img src="@Model.Card!.EmergencyInfoQrImageDataUrl" alt="QR datos de emergencia" />
                                        <div class="policy-emergency-caption">Escanéame en caso de emergencia</div>
                                    </div>
                                }
                                else if (Model.ShowQr)
                                {
                                    <div class="policy-emergency-scan" aria-label="Escanéame en caso de emergencia">
                                        <i class="fas fa-qrcode policy-emergency-icon" aria-hidden="true"></i>
                                        <span class="policy-emergency-line1">Escanéame</span>
                                        <span class="policy-emergency-line2">en caso de</span>
                                        <span class="policy-emergency-line3">emergencia</span>
                                    </div>
                                }
                            </div>

                            @* ZONA 6: Footer *@
                            <div class="idcard-footer-front idcard-z1">Emitido: @DateTime.UtcNow.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>

                <div class="print-actions">
                    <button type="button" class="btn btn-primary btn-lg" id="btnDownloadPdf"
                            data-pdf-url="@Url.Action("Print", "StudentIdCard", new { studentId = Model.Card!.StudentId })"
                            data-filename="@($"carnet-{Model.Card.StudentId:N}.pdf")">
                        <i class="fas fa-file-pdf"></i> Descargar PDF
                    </button>
                    <button type="button" class="btn btn-warning btn-lg" id="btnRegenerate" onclick="generateCard('@Model.Card.StudentId')">
                        <i class="fas fa-sync-alt"></i> Regenerar carnet
                    </button>
                    <a href="@Url.Action("Index", "StudentIdCard")" class="btn btn-secondary btn-lg"><i class="fas fa-arrow-left"></i> Volver</a>
                </div>
            </div>
        </div>
    }
</div>

<script>
    window.adjustIdCardQrForLongName = function (root) {
        root = root || document.getElementById('idCardFront');
        if (!root) return;
        var nameEl = root.querySelector('.idcard-student-name');
        var footerEl = root.querySelector('.idcard-bottom-footer');
        if (!nameEl || !footerEl) return;

        var MAX_LIFT = 8;
        var MIN_LIFT = 5;
        var ANCHOR_GAP = 2;

        function resetFooterAdjust() {
            footerEl.classList.remove('idcard-bottom-footer--raised', 'idcard-bottom-footer--qr-compact');
            footerEl.style.removeProperty('--idcard-footer-raise');
            footerEl.style.removeProperty('--idcard-qr-scale');
        }

        function getDataAnchor() {
            var nodes = root.querySelectorAll(
                '.idcard-student-year, .idcard-student-grade, .idcard-student-document, .idcard-student-name');
            var anchor = null;
            var maxBottom = -1;
            nodes.forEach(function (el) {
                var b = el.getBoundingClientRect().bottom;
                if (b > maxBottom) {
                    maxBottom = b;
                    anchor = el;
                }
            });
            return anchor;
        }

        function applyState(liftPx, qrCompact, qrScale) {
            resetFooterAdjust();
            if (liftPx > 0) {
                footerEl.style.setProperty('--idcard-footer-raise', liftPx + 'px');
                footerEl.classList.add('idcard-bottom-footer--raised');
            }
            if (qrCompact) {
                footerEl.classList.add('idcard-bottom-footer--qr-compact');
                footerEl.style.setProperty('--idcard-qr-scale', (qrScale || 0.9).toString());
            }
        }

        function overlapsAnchor(liftPx) {
            var anchor = getDataAnchor();
            if (!anchor) return false;
            applyState(liftPx, false, null);
            var footerTop = footerEl.getBoundingClientRect().top;
            var anchorBottom = anchor.getBoundingClientRect().bottom;
            var overlap = footerTop < anchorBottom + ANCHOR_GAP;
            resetFooterAdjust();
            return overlap;
        }

        function isQrClipped() {
            var cardRect = root.getBoundingClientRect();
            var qrEl = footerEl.querySelector('.policy-emergency-qr, .policy-emergency-scan');
            var target = qrEl || footerEl;
            var r = target.getBoundingClientRect();
            return r.bottom > cardRect.bottom - 0.5;
        }

        resetFooterAdjust();

        var style = window.getComputedStyle(nameEl);
        var lineHeight = parseFloat(style.lineHeight);
        if (!lineHeight || Number.isNaN(lineHeight)) {
            lineHeight = parseFloat(style.fontSize) * 1.15;
        }

        var nameH = nameEl.getBoundingClientRect().height;
        if (nameH <= lineHeight * 1.25 + 0.5) return;

        var safeLift = 0;
        for (var lift = MAX_LIFT; lift >= MIN_LIFT; lift--) {
            if (!overlapsAnchor(lift)) {
                safeLift = lift;
                break;
            }
        }

        applyState(safeLift, false, null);
        if (!isQrClipped()) return;

        var scales = [0.9, 0.85, 0.8];
        for (var s = 0; s < scales.length; s++) {
            applyState(safeLift, true, scales[s]);
            if (!isQrClipped()) return;
        }

        applyState(0, true, 0.8);
    };

    (function () {
        function runQrAdjust() {
            if (typeof window.adjustIdCardQrForLongName === 'function') {
                window.adjustIdCardQrForLongName();
            }
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', runQrAdjust);
        } else {
            runQrAdjust();
        }
        if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(runQrAdjust);
        }
    })();
</script>
<script>
    (function () {
        var btn = document.getElementById('btnDownloadPdf');
        if (!btn) return;
        btn.addEventListener('click', async function () {
            var url = btn.getAttribute('data-pdf-url');
            var name = btn.getAttribute('data-filename') || 'carnet.pdf';
            btn.disabled = true;
            var prev = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generando PDF...';
            try {
                var r = await fetch(url, { method: 'GET', credentials: 'same-origin', cache: 'no-store' });
                var ct = (r.headers.get('content-type') || '').toLowerCase();
                if (r.status === 401) {
                    if (window.SchoolUi) {
                        window.SchoolUi.warning('Sesión finalizada', 'Inicie sesión de nuevo y vuelva a descargar el carnet.');
                    } else alert('Sesión expirada.');
                    return;
                }
                if (!r.ok) {
                    var errText = await r.text();
                    var msg = errText || ('No se pudo generar el PDF (código ' + r.status + ').');
                    if (window.SchoolUi) window.SchoolUi.error('No se pudo descargar el PDF', msg.length > 600 ? msg.substring(0, 600) + '…' : msg);
                    else alert(msg);
                    return;
                }
                if (!ct.includes('pdf')) {
                    var t = await r.text();
                    var preview = t.substring(0, 500) || 'El servidor no devolvió un archivo PDF.';
                    if (window.SchoolUi) {
                        window.SchoolUi.error('Archivo no válido', preview.length > 400 ? preview.substring(0, 400) + '…' : preview);
                    } else alert(preview);
                    return;
                }
                var blob = await r.blob();
                var a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = name;
                document.body.appendChild(a);
                a.click();
                a.remove();
                URL.revokeObjectURL(a.href);
            } catch (e) {
                if (window.SchoolUi) {
                    window.SchoolUi.error('Sin conexión', 'Compruebe su internet o intente más tarde.');
                } else alert('Error de red al descargar el PDF.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = prev;
            }
        });
    })();
</script>
<script>
    function generateCard(id) {
        var btn = document.getElementById('btnGenerate') || document.getElementById('btnRegenerate');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generando...';
        }
        var antiforgeryInput = document.querySelector('input[name="__RequestVerificationToken"]');
        fetch('/StudentIdCard/api/generate/' + id, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': antiforgeryInput ? antiforgeryInput.value : ''
            }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data && data.cardNumber) {
                window.location.href = '/StudentIdCard/ui/generate/' + id;
            } else {
                var gm = data.message || 'No se pudo generar el carnet. Si el problema continúa, contacte al administrador.';
                if (window.SchoolUi) window.SchoolUi.error('No se pudo generar el carnet', gm);
                else alert('Error: ' + gm);
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-id-card"></i> Generar carnet'; }
            }
        })
        .catch(function () {
            if (window.SchoolUi) {
                window.SchoolUi.error('Error de conexión', 'No pudimos comunicarnos con el servidor. Revise su red e intente de nuevo.');
            } else alert('Error de red al generar el carnet.');
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-id-card"></i> Generar carnet'; }
        });
    }
</script>
