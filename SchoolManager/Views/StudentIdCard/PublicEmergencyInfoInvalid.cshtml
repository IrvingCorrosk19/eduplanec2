@{
    Layout = null;
    ViewData["Title"] = "Enlace no válido";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; background: #f1f5f9; color: #334155; }
        .box { max-width: 360px; text-align: center; background: #fff; padding: 28px 22px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,.08); }
        h1 { font-size: 1.1rem; margin: 0 0 10px; color: #b91c1c; }
        p { margin: 0; font-size: .9rem; line-height: 1.45; }
    </style>
</head>
<body>
    <div class="box">
        <h1>No se pudo mostrar la información</h1>
        <p>El código QR está dañado, expiró o no es válido. Solicite un carnet actualizado en su institución.</p>
    </div>
</body>
</html>
