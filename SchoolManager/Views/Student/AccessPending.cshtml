@{
    ViewData["Title"] = "Acceso a la plataforma pendiente";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Acceso a la plataforma pendiente
                    </h4>
                </div>
                <div class="card-body">
                    <p class="lead mb-3">
                        Su acceso a la plataforma aún no ha sido activado.
                    </p>
                    <p class="text-muted mb-3">
                        Por favor contacte al Club de Padres de Familia de su institución para regularizar el pago del servicio.
                    </p>
                    <p class="text-muted mb-0">
                        Una vez registrado el pago, su acceso será habilitado automáticamente.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
