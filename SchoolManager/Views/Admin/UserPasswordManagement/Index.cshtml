@model SchoolManager.ViewModels.UserPasswordManagementIndexViewModel
@{
    ViewData["Title"] = "User Password Management";
    Layout = "_AdminLayout";
    var indexUrl = Url.Action("Index", "UserPasswordManagement")!;
    string RoleDisplay(string? role)
    {
        var r = (role ?? "").ToLowerInvariant();
        return r switch
        {
            "superadmin" => "SuperAdmin",
            "admin" => "Admin",
            "teacher" => "Teacher",
            "student" or "estudiante" => "Student",
            _ => role ?? ""
        };
    }
}

<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>User Password Management</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Inicio</a></li>
                        <li class="breadcrumb-item active">User Password Management</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">
            @Html.AntiForgeryToken()
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-key mr-2"></i>User Password Management</h3>
                </div>
                <div class="card-body">
                    @* Un solo GET: grado, grupo, rol y búsqueda viajan juntos en la URL (no POST). *@
                    <form method="get" action="@indexUrl" id="filterForm" class="mb-4">
                        <div class="row align-items-end g-2">
                            <div class="col-md-2">
                                <label class="form-label" for="gradeId">Grado</label>
                                <select name="gradeId" id="gradeId" class="form-control">
                                    <option value="">Todos</option>
                                    @foreach (var g in Model.GradeLevels)
                                    {
                                        if (Model.SelectedGradeId == g.Id)
                                        { <option value="@g.Id" selected>@g.Name</option> }
                                        else
                                        { <option value="@g.Id">@g.Name</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" for="groupId">Grupo</label>
                                <select name="groupId" id="groupId" class="form-control">
                                    <option value="">Todos</option>
                                    @foreach (var gr in Model.Groups)
                                    {
                                        if (Model.SelectedGroupId == gr.Id)
                                        { <option value="@gr.Id" selected>@gr.Name</option> }
                                        else
                                        { <option value="@gr.Id">@gr.Name</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" for="role">Rol</label>
                                <select name="role" id="role" class="form-control">
                                    @if (string.IsNullOrEmpty(Model.SelectedRole))
                                    { <option value="" selected>Todos</option> }
                                    else
                                    { <option value="">Todos</option> }
                                    @if (Model.SelectedRole == "superadmin")
                                    { <option value="superadmin" selected>SuperAdmin</option> }
                                    else
                                    { <option value="superadmin">SuperAdmin</option> }
                                    @if (Model.SelectedRole == "admin")
                                    { <option value="admin" selected>Admin</option> }
                                    else
                                    { <option value="admin">Admin</option> }
                                    @if (Model.SelectedRole == "teacher")
                                    { <option value="teacher" selected>Teacher</option> }
                                    else
                                    { <option value="teacher">Teacher</option> }
                                    @if (Model.SelectedRole == "student")
                                    { <option value="student" selected>Student</option> }
                                    else
                                    { <option value="student">Student</option> }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" for="q">Buscar</label>
                                <input type="text" name="q" id="q" class="form-control" placeholder="Nombre, apellido o email…" value="@Model.SearchQuery" />
                            </div>
                            <div class="col-md-3 d-flex flex-wrap gap-2 align-items-end pb-1">
                                <button type="submit" class="btn btn-info">
                                    <i class="fas fa-filter mr-1"></i> Filtrar
                                </button>
                                <a href="@indexUrl" class="btn btn-outline-secondary">
                                    <i class="fas fa-times mr-1"></i> Limpiar filtros
                                </a>
                            </div>
                        </div>
                    </form>

                    <div class="row mb-3">
                        <div class="col-md-12 d-flex flex-wrap gap-2 justify-content-end">
                            <button type="button" id="btnSendPasswords" class="btn btn-primary">
                                <i class="fas fa-envelope mr-1"></i> Enviar contraseñas
                            </button>
                            <button type="button" id="btnReset" class="btn btn-secondary" title="Quitar solo rol y búsqueda; mantiene grado y grupo">
                                <i class="fas fa-undo mr-1"></i> Quitar rol y búsqueda
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table id="usersTable" class="table table-bordered table-striped table-hover" style="width:100%">
                            <thead>
                                <tr>
                                    <th style="width: 40px;">
                                        <input type="checkbox" id="selectAll" title="Select all" />
                                    </th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Grado</th>
                                    <th>Grupo</th>
                                    <th>Status</th>
                                    <th>Estado correo</th>
                                    <th>Fecha envío</th>
                                    <th>Created At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in Model.Users)
                                {
                                    var name = $"{u.FirstName} {u.LastName}".Trim();
                                    if (string.IsNullOrEmpty(name)) { name = u.Email; }
                                    <tr data-id="@u.Id">
                                        <td><input type="checkbox" class="user-select-cb" value="@u.Id" /></td>
                                        <td>@name</td>
                                        <td>@u.Email</td>
                                        <td class="col-role">@RoleDisplay(u.Role)</td>
                                        <td>@(string.IsNullOrEmpty(u.Grade) || u.Grade == "-" ? "-" : u.Grade)</td>
                                        <td>@(string.IsNullOrEmpty(u.Group) || u.Group == "-" ? "-" : u.Group)</td>
                                        <td>@u.Status</td>
                                        <td>@(u.PasswordEmailStatus ?? "")</td>
                                        <td>@(u.PasswordEmailSentAt.HasValue ? u.PasswordEmailSentAt.Value.ToLocalTime().ToString("g") : "")</td>
                                        <td>@(u.CreatedAt.HasValue ? u.CreatedAt.Value.ToLocalTime().ToString("g") : "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="~/js/userPasswordManagement.js" asp-append-version="true"></script>
    <script>
        $(function () {
            userPasswordManagement.init({
                serverRendered: true,
                sendPasswordsUrl: '@Url.Action("SendPasswords", "UserPasswordManagement")',
                indexUrl: '@indexUrl'
            });
        });
    </script>
}
