@model SchoolManager.ViewModels.StaffMemberPublicProfileVm
@using SchoolManager.Helpers
@{
    Layout = null;
    ViewData["Title"] = "Perfil institucional";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 0; padding: 16px; background: #f1f5f9; color: #0f172a; }
        .card { max-width: 420px; margin: 0 auto; background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,.08); overflow: hidden; }
        .head { background: linear-gradient(135deg, #1e40af, #2563eb); color: #fff; padding: 18px 16px; text-align: center; }
        .head h1 { margin: 0; font-size: 1.15rem; font-weight: 700; }
        .head p { margin: 6px 0 0; font-size: .8rem; opacity: .95; }
        .body { padding: 16px; }
        .photo { text-align: center; margin-bottom: 12px; }
        .photo img { width: 96px; height: 96px; object-fit: cover; border-radius: 50%; border: 2px solid #e2e8f0; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        dl { margin: 0; }
        dt { font-size: .68rem; text-transform: uppercase; letter-spacing: .04em; color: #64748b; margin-top: 12px; }
        dt:first-child { margin-top: 0; }
        dd { margin: 4px 0 0; font-size: .95rem; font-weight: 600; color: #1e293b; }
        .status-pill { display: inline-block; margin-top: 4px; padding: 4px 10px; border-radius: 999px; font-size: .8rem; font-weight: 700; }
        .status-pill--active { background: #dcfce7; color: #166534; }
        .status-pill--inactive { background: #fee2e2; color: #991b1b; }
        .muted { color: #64748b; font-weight: 500; }
        .eduplaner-cta {
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid #e2e8f0;
            text-align: center;
        }
        .btn-eduplaner {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            max-width: 100%;
            padding: 14px 20px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #2563eb 0%, #0d6efd 50%, #0a58ca 100%);
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            letter-spacing: .02em;
            box-shadow: 0 4px 14px rgba(13, 110, 253, .35);
            transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
            -webkit-tap-highlight-color: transparent;
        }
        .btn-eduplaner:hover,
        .btn-eduplaner:focus {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(13, 110, 253, .45);
            filter: brightness(1.05);
        }
        .btn-eduplaner:active {
            transform: translateY(0);
            box-shadow: 0 2px 10px rgba(13, 110, 253, .3);
        }
        .btn-eduplaner__sub {
            display: block;
            margin-top: 8px;
            font-size: .72rem;
            font-weight: 500;
            color: #64748b;
        }
        .foot { padding: 12px 16px; font-size: .7rem; color: #94a3b8; text-align: center; background: #f8fafc; }
    </style>
</head>
<body>
    <div class="card">
        <div class="head">
            <h1>Personal institucional</h1>
            <p>Verificación de identidad · Solo lectura</p>
        </div>
        <div class="body">
            <div class="photo">
                <img src="@UserPhotoLinks.Href(Model.PhotoUrl)" alt="Foto" />
            </div>
            <dl>
                <dt>Nombre completo</dt>
                <dd>@Model.FullName</dd>

                <dt>Estado de cuenta</dt>
                <dd>
                    @if (Model.IsAccountActive)
                    {
                        <span class="status-pill status-pill--active">Activo</span>
                    }
                    else
                    {
                        <span class="status-pill status-pill--inactive">Inactivo</span>
                    }
                </dd>

                <dt>Estado credencial</dt>
                <dd>@Model.CredentialStatusDisplay</dd>

                @if (!string.IsNullOrWhiteSpace(Model.RoleDisplay))
                {
                    <dt>Rol</dt>
                    <dd>@Model.RoleDisplay</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.JobTitle) && Model.JobTitle != "—")
                {
                    <dt>Cargo</dt>
                    <dd>@Model.JobTitle</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Department) && Model.Department != "—")
                {
                    <dt>Departamento / área</dt>
                    <dd>@Model.Department</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SchoolName))
                {
                    <dt>Escuela</dt>
                    <dd>@Model.SchoolName</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmployeeCode))
                {
                    <dt>Código institucional</dt>
                    <dd>@Model.EmployeeCode</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Email))
                {
                    <dt>Correo institucional</dt>
                    <dd class="muted" style="word-break:break-all;">@Model.Email</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.BloodType))
                {
                    <dt>Tipo de sangre</dt>
                    <dd>@Model.BloodType</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Allergies))
                {
                    <dt>Alergias</dt>
                    <dd>@Model.Allergies</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmergencyContactName))
                {
                    <dt>Contacto de emergencia</dt>
                    <dd>@Model.EmergencyContactName</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmergencyContactPhone))
                {
                    <dt>Teléfono de emergencia</dt>
                    <dd>@Model.EmergencyContactPhone</dd>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmergencyRelationship))
                {
                    <dt>Relación (emergencia)</dt>
                    <dd>@Model.EmergencyRelationship</dd>
                }
            </dl>

            <div class="eduplaner-cta">
                <a class="btn-eduplaner" href="https://eduplaner.net/" rel="noopener noreferrer" target="_blank">
                    <span aria-hidden="true">↗</span>
                    Ir a Eduplaner
                </a>
                <span class="btn-eduplaner__sub">Sistema de gestión educativa · eduplaner.net</span>
            </div>
        </div>
        <div class="foot">Información publicada por la institución educativa. Si este enlace no corresponde, ignore la página.</div>
    </div>
</body>
</html>
